local function GetFolders()
	return Library.Folders or Folder_Configs
end

local function GetAssetsAudiosFolder()
	local Assets = GetFolders().Assets
	local NewPath = Assets .. "/Audios"
	local OldPath = Assets .. "/Audio"

	if isfolder(NewPath) then
		return NewPath
	end

	if isfolder(OldPath) then
		return OldPath
	end

	return NewPath
end

local function GetAssetsFontsFolder()
	local Assets = GetFolders().Assets
	local NewPath = Assets .. "/Fonts"
	local OldPath = Assets .. "/fonts"

	if isfolder(NewPath) then
		return NewPath
	end

	if isfolder(OldPath) then
		return OldPath
	end

	return NewPath
end

local function GetAutoloadPath()
	return Folder_Configs.Configurations .. "/" .. GameId .. "/autoload.json"
end

local function GetAutoloadConfigNamePath()
	return Folder_Configs.Configurations .. "/" .. GameId .. "/autoload_config.txt"
end

local function GetAutoloadConfigName()
	local AutoloadNamePath = GetAutoloadConfigNamePath()

	if isfile(AutoloadNamePath) then
		local Success, Name = pcall(readfile, AutoloadNamePath)

		if Success and type(Name) == "string" then
			Name = (Name:gsub("^%s+", ""):gsub("%s+$", ""))
			if Name ~= "" then
			return Name
			end
		end
	end

	return "none"
end

local function GetAutoloadThemeNamePath()
	return Folder_Configs.Themes .. "/autoload_theme.txt"
end

local function GetLocalSettingsPath()
	return Folder_Configs.Datas .. "/" .. GameId .. "/settings.json"
end

