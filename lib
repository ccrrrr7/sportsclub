		local function set_preview_placeholder(text, visible)
			if not Textbox.Preview then return end
			Items["PreviewPlaceholder"].Instance.Text = text or "image preview"
			Items["PreviewPlaceholder"].Instance.Visible = visible == true
		end

		local function clear_preview()
			if not Textbox.Preview then return end
			Items["PreviewImage"].Instance.Image = ""
			Items["PreviewImage"].Instance.ImageTransparency = 1
			set_preview_placeholder("image preview", true)
		end

		local function apply_preview_image(image_id)
			if not Textbox.Preview or type(image_id) ~= "string" or image_id == "" then return end
			Items["PreviewImage"].Instance.Image = image_id
			Items["PreviewImage"].Instance.ImageTransparency = 0
			set_preview_placeholder(nil, false)
		end

		function Textbox:UpdatePreview(Value)
			if not Textbox.Preview then return end
			local string_value = Library:TrimImageTextboxInput(Value)
			if not Library:IsValidImageTextboxInput(string_value) then
				clear_preview()
				return
			end

			Textbox.PreviewToken = Textbox.PreviewToken + 1
			local preview_token = Textbox.PreviewToken
			local numeric_id = string_value:match("^(%d+)$") or string_value:match("^rbxassetid://(%d+)")
			if numeric_id then
				apply_preview_image("rbxassetid://" .. numeric_id)
				return
			end

			set_preview_placeholder("loading...", true)
			Items["PreviewImage"].Instance.ImageTransparency = 1
			task.spawn(function()
				local image_id = Library:ResolveImageTextboxPreview(string_value)
				if Textbox.PreviewToken ~= preview_token then return end
				if type(image_id) == "string" and image_id ~= "" then
					apply_preview_image(image_id)
				else
					Items["PreviewImage"].Instance.Image = ""
					Items["PreviewImage"].Instance.ImageTransparency = 1
					set_preview_placeholder("failed to load", true)
				end
			end)
		end

		function Textbox:Get()
			return Textbox.Value
		end

		function Textbox:SetDisabled(Bool)
			Textbox.Disabled = Bool == true
			local text_trans = Textbox.Disabled and 0.6 or 0
			if Items["Text"] then Items["Text"]:Tween(nil, {TextTransparency = text_trans}) end
			Items["Background"]:Tween(nil, {BackgroundTransparency = text_trans})
			Items["Input"]:Tween(nil, {TextTransparency = text_trans})
			if Items["PreviewBackground"] then Items["PreviewBackground"]:Tween(nil, {BackgroundTransparency = text_trans}) end
			if Items["PreviewImage"] then Items["PreviewImage"]:Tween(nil, {ImageTransparency = text_trans}) end
			if Items["PreviewPlaceholder"] then Items["PreviewPlaceholder"]:Tween(nil, {TextTransparency = text_trans}) end
			InputInstance.Interactable = Textbox.Disabled ~= true
		end

		function Textbox:SetVisibility(Bool)
			Items["TextboxContainer"].Instance.Visible = Bool == true
			Library:DeferSectionLayoutRefresh(Textbox.Section)
		end

		Textbox.SetVisible = Textbox.SetVisibility

		function Textbox:Set(Value, Silent)
			if Textbox.Disabled then return end
			if not Library:CheckLifetime(Textbox, "Textbox") then return end
			local String = tostring(Value or "")
			Textbox.Value = String
			if InputInstance.Text ~= String then InputInstance.Text = String end
			if Textbox.Flag then Library.Flags[Textbox.Flag] = String end
			if Textbox.Callback and Library:ShouldFireElementCallback(Silent) then
				Library:SafeCall(Textbox.Callback, String, Library:IsValidImageTextboxInput(String))
			end
			Textbox:UpdatePreview(String)
			if Library:ShouldSaveAutoload(Silent) then Library:SaveAutoloadIfEnabled() end
		end

		function Textbox:IsValid(Value)
			return Library:IsValidImageTextboxInput(Value or Textbox.Value)
		end

		if Textbox.Finished then
			Items["Input"]:Connect("FocusLost", function()
				if Textbox.Disabled or not Library:CheckLifetime(Textbox) then return end
				Textbox:Set(InputInstance.Text)
			end)
		else
			Library:Connect(InputInstance:GetPropertyChangedSignal("Text"), function()
				if Textbox.Disabled or not Library:CheckLifetime(Textbox) then return end
				Textbox:Set(InputInstance.Text)
			end)
		end

		if Textbox.Default and Textbox.Default ~= "" then Textbox:Set(Textbox.Default, true) end

		Library:BindElementFlag(Textbox.Flag, function(Value)
			if Textbox.Disabled then return end
			Textbox:Set(Value, Library.LoadingConfig == true)
		end, Textbox)

		Textbox.Items = Items
		return Textbox
	end

	Library.CreateFontSettingsSection = function(self, Page, Data)
		Data = Data or {}

		local Section = Page:Section({
			Name = Data.Name or Data.name or "Fonts",
