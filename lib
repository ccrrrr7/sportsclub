                end
            end

            local forward_accel_sample = accel_x * dir_x + accel_y * dir_y + accel_z * dir_z
            local lateral_x = accel_x - (dir_x * forward_accel_sample)
            local lateral_y = accel_y - (dir_y * forward_accel_sample)
            local lateral_z = accel_z - (dir_z * forward_accel_sample)
            local lateral_accel_sample = math_sqrt(lateral_x * lateral_x + lateral_y * lateral_y + lateral_z * lateral_z)
            local accel_weight = 1 - ((offset - 1) / math_max(count - 1, 1))
            accel_weight = 0.35 + accel_weight * 0.65
            local forward_noise = abs(forward_accel_sample - last_forward_accel)
            local lateral_noise = abs(lateral_accel_sample - last_lateral_accel)
            local consistency_weight = 1 - math_clamp((forward_noise + lateral_noise) / 280, 0, 0.55)
            accel_weight = accel_weight * consistency_weight
            smooth_forward_accel = smooth_forward_accel * accel_smoothness + (forward_accel_sample * accel_weight) * (1 - accel_smoothness)
            smooth_lateral_accel = smooth_lateral_accel * accel_smoothness + (lateral_accel_sample * accel_weight) * (1 - accel_smoothness)
            last_forward_accel = forward_accel_sample
            last_lateral_accel = lateral_accel_sample
            weighted_samples = weighted_samples + 1

            local closing_speed = (history.dist[current_index] - history.dist[next_index]) / dt
            if closing_speed > 1 then
                local eta_value = history.dist[next_index] / closing_speed
                eta_count = eta_count + 1
                eta_sum = eta_sum + eta_value
            end
