    end)

    sportsclub_functions["GetConfidenceScore"] = LPH_JIT_MAX(function(tti, dist, dot, closing, curve_strength, smoothed_ping, jitter, eta_stability, profile, predicted_curve_threat, predicted_curve_confidence, forward_accel, lateral_accel, closeness_trend, direction_changed_recently)
