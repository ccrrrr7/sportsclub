			Library:SaveLocalSettings()
			return true
		end

		if Index == "Background Darken" and type(Value) == "boolean" then
			Library:SetBackgroundDarkenEnabled(Value)
			return true
		end

		if Index == "Auto Execute" and type(Value) == "boolean" then
			Library.AutoExecute = Value
			Library:SaveLocalSettings()
			return true
		end

		if Index == "UI Font" and type(Value) == "string" then
			Library:SetFont(Value)
			return true
		end

		local SetFunction = Library.SetFlags[Index]

		if not SetFunction then
			self:StoreRawConfigFlag(Index, Value)
			return true
		end

		local NormalizedValue, NormalizedAlpha = self:NormalizeLoadedConfigValue(Index, Value)

		if type(NormalizedValue) == "string" and type(NormalizedAlpha) == "number" then
			SetFunction(NormalizedValue, NormalizedAlpha)
		elseif type(NormalizedValue) == "table" and NormalizedValue.Key then
			SetFunction(NormalizedValue)
		elseif type(NormalizedValue) == "table" and NormalizedValue.Color then
			SetFunction(NormalizedValue.Color, NormalizedValue.Alpha)
		else
			SetFunction(NormalizedValue)
		end

		return true
	end

