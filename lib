	Library.GetConfig = function(self)
		local Config = {}

		local Success, Result = Library:SafeCall(function()
			for Index, Value in Library.Flags do
				if Library:IsScriptConfigFlag(Index) ~= true then
					continue
				end

				local CompactValue

				if type(Value) == "table" and Value.Key then
					CompactValue = { Key = tostring(Value.Key), Mode = Value.Mode }
				elseif type(Value) == "table" and Value.Color then
					local HexValue = Value.HexValue or Value.Color

					if typeof(HexValue) == "Color3" then
						HexValue = HexValue:ToHex()
					end

					if type(HexValue) == "string" and HexValue:sub(1, 1) == "#" then
						HexValue = HexValue:sub(2)
					end

					CompactValue = {
						Color = "#" .. tostring(HexValue),
						Alpha = self:RoundConfigNumber(Value.Alpha or 0, 4),
					}
				elseif self.HideRangeSubSliderFlags[Index] == true and type(Value) == "table" and Value.Speed ~= nil then
					local DefaultValue = self.FlagDefaults[Index]
					local DefaultStart = type(DefaultValue) == "table" and DefaultValue.Start or 0
					local DefaultEnd = type(DefaultValue) == "table" and (DefaultValue["End"] or DefaultValue.End) or 100
					local CurrentStart = Value.Start
					local CurrentEnd = Value["End"] or Value.End

					if self:RoundConfigNumber(CurrentStart or 0, 4) == self:RoundConfigNumber(DefaultStart, 4)
						and self:RoundConfigNumber(CurrentEnd or 100, 4) == self:RoundConfigNumber(DefaultEnd, 4) then
						CompactValue = self:RoundConfigNumber(Value.Speed, 4)
					else
						CompactValue = self:CompactConfigValue(Value)
					end
				else
					CompactValue = self:CompactConfigValue(Value)
				end

				local DefaultValue = self.FlagDefaults[Index]

				if DefaultValue ~= nil then
					local DefaultCompact = self:CompactConfigValue(DefaultValue)

					if type(CompactValue) == "number" and type(DefaultCompact) == "table" and DefaultCompact.Speed ~= nil then
						if self:RoundConfigNumber(CompactValue, 4) == self:RoundConfigNumber(DefaultCompact.Speed, 4) then
							continue
						end
					elseif self:ConfigValuesEqual(CompactValue, DefaultCompact) then
						continue
					end
				end

				Config[Index] = CompactValue
			end
		end)

		return HttpService:JSONEncode(Config)
	end

	Library.LoadConfig = function(self, Config)
		local DecodeSuccess, Decoded = pcall(HttpService.JSONDecode, HttpService, Config)

		if not DecodeSuccess or type(Decoded) ~= "table" then
			return false, tostring(Decoded)
		end

		self:BeginSilent()
		self.LoadingConfig = true

		local FailedEntries = {}

		for Index, Value in Decoded do
			if self:IsScriptConfigFlag(Index) ~= true then
				continue
			end

			local ApplySuccess, ApplyError = pcall(function()
				self:ApplyConfigEntry(Index, Value)
			end)

			if not ApplySuccess then
				TableInsert(FailedEntries, tostring(Index) .. ": " .. tostring(ApplyError))
			end
		end

		self:FinishConfigLoad(Decoded, FailedEntries)

		return true
	end

	Library.RefreshConfigsList = function(self, Element)
		local List = {}
		local ReturnList = {}

		List = listfiles(Library:GetFolder())

		for Index = 1, #List do 
			local File = List[Index]

			if File:sub(-5) == ".json" then
				local Position = File:find(".json", 1, true)
				local StartPosition = Position

				local Character = File:sub(Position, Position)

				while Character ~= "/" and Character ~= "\\" and Character ~= "" do
					Position = Position - 1
					Character = File:sub(Position, Position)
				end

				if Character == "/" or Character == "\\" then
					TableInsert(ReturnList, File:sub(Position + 1, StartPosition - 1))
				end
			end
		end

		Element:Refresh(ReturnList)
	end

