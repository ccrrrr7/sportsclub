		end

		if Title then
			self.FontSettings.TitleTextSize = MathClamp(MathFloor(Title), 14, 28)
		end

		self:ApplyFontSettings()

		if not SkipSave and not self.LoadingConfig then
			self:SaveLocalSettings()
		end
	end

