	local function RunWithThreadIdentity(Identity, Function, ...)
		if type(Function) ~= "function" then
			return false, "invalid callback"
		end

		local OldIdentity = (type(getthreadidentity) == "function" and getthreadidentity()) or 2

		if type(setthreadidentity) == "function" then
			pcall(setthreadidentity, tonumber(Identity) or 2)
		end

		local Results = table.pack(pcall(Function, ...))

		if type(setthreadidentity) == "function" then
			pcall(setthreadidentity, OldIdentity)
		end

		return Results[1], table.unpack(Results, 2, Results.n)
	end

	local ELEVATED_IDENTITIES = { 8, 7, 2 }

	local function RunWithElevatedThreadIdentity(Function, ...)
		for index = 1, #ELEVATED_IDENTITIES do
			local Success, Result = RunWithThreadIdentity(ELEVATED_IDENTITIES[index], Function, ...)
			if Success then
				return Success, Result
			end
		end

		return false, "gui mutation failed"
	end

	local function IsRobloxInstance(Value)
		if Value == nil then
			return false
		end

		return pcall(function()
			return Value.ClassName
		end)
	end

	local function GetWrapperInstance(Wrapper)
		if type(Wrapper) ~= "table" or not Wrapper.Instance then
			return nil
		end

		return Wrapper.Instance
	end

	local gui_mutation_queue = {}
	local gui_mutation_flush_connected = false

	local function flush_gui_mutations()
		if #gui_mutation_queue == 0 then return end
		local batch = gui_mutation_queue
		gui_mutation_queue = {}
		RunWithElevatedThreadIdentity(function()
			for index = 1, #batch do
				pcall(batch[index])
			end
		end)
	end

	local function ensure_gui_mutation_flush()
		if gui_mutation_flush_connected then return end
		gui_mutation_flush_connected = true
		RunService.Heartbeat:Connect(flush_gui_mutations)
	end

	local function RunGuiMutation(Function)
		if type(Function) ~= "function" then
			return false
		end

		local current_identity = (type(getthreadidentity) == "function" and getthreadidentity()) or 2
		if current_identity >= 7 then
			local Success = select(1, RunWithElevatedThreadIdentity(Function))
			if Success then
				return true
			end
		end

		ensure_gui_mutation_flush()
		gui_mutation_queue[#gui_mutation_queue + 1] = Function
		return true
	end

	local function SetInstanceParent(InstanceObject, Parent)
		if not IsRobloxInstance(InstanceObject) then
			return false
		end

		local Success = RunWithElevatedThreadIdentity(function()
			InstanceObject.Parent = Parent
		end)

		return Success == true
	end

