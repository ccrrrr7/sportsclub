                    eta_deviation = eta_deviation + abs(eta_value - avg_eta)
                end
            end
        end
        local eta_stability = eta_count >= 3 and (1 - math_clamp((eta_deviation / eta_count) / math_max(avg_eta, 0.05), 0, 1)) or 1

