    function library:load_style(style_json)
        local style = http_service:JSONDecode(style_json)
        local theme_values = style.themes or style
        local style_settings = style.settings or {}

        for theme_name, value in theme_values do
            if themes.preset[theme_name] then
                library:update_theme(theme_name, hex(value))
            end
        end

        library:update_menu_scale(style_settings.menu_scale or 1)
        library:update_theme_transparency("window", style_settings.window_transparency or 0)
        library:update_theme_transparency("section", style_settings.section_transparency or 0)
        library:update_shadow_transparency(style_settings.shadow_transparency ~= nil and style_settings.shadow_transparency or 1)
        library.style_state.notify_side = style_settings.notify_side or library.style_state.notify_side
        library.style_state.sidebar_search_enabled = style_settings.sidebar_search_enabled ~= false
        library:update_mobile_button_scale(style_settings.mobile_button_scale or 1)
        library:update_mobile_buttons_visibility(style_settings.show_mobile_buttons ~= false)
        if library.menu_window and library.menu_window.update_sidebar_search_visibility then
            library.menu_window.update_sidebar_search_visibility(library.style_state.sidebar_search_enabled)
        end
        if library.menu_window and library.menu_window.update_sidebar_width then
            library.menu_window.update_sidebar_width(style_settings.sidebar_width or library.style_state.sidebar_width or 196)
        end
    end

