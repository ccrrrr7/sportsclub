	local function BindTwoColumnLayout(Container, ColumnsData)
		local HalfGap = math.ceil(COLUMN_GAP / 2)

		local function Update()
			local Width = Container.AbsoluteSize.X
			local Height = Container.AbsoluteSize.Y
			if Width < 2 or Height < 2 then
				return
			end

			local Column1 = ColumnsData[1]
			local Column2 = ColumnsData[2]

			if Column1 then
				Column1.Instance.AnchorPoint = Vector2New(0, 0)
				Column1.Instance.Position = UDim2New(0, 0, 0, 0)
				Column1.Instance.Size = UDim2New(0.5, -HalfGap, 1, 0)
			end

			if Column2 then
				Column2.Instance.AnchorPoint = Vector2New(0, 0)
				Column2.Instance.Position = UDim2New(0.5, HalfGap, 0, 0)
				Column2.Instance.Size = UDim2New(0.5, -HalfGap, 1, 0)
			end
		end

		Container:GetPropertyChangedSignal("AbsoluteSize"):Connect(Update)
		defer(Update)
		task.delay(0.05, Update)

		return Update
	end

	local function SetupColumnsLayout(ParentWrapper, ColumnsData)
		local ParentInstance = ParentWrapper.Instance or ParentWrapper

		local SideZeroWrapper = Instances:Create("Frame", {
			Parent = ParentInstance,
			Name = "\0",
			Size = UDim2New(1, 0, 0, 0),
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			ClipsDescendants = true,
			ZIndex = 3,
		})

		ColumnsData[0] = CreateSectionColumn(SideZeroWrapper.Instance, { BottomPad = 0 })
		ColumnsData[0].Instance.Size = UDim2New(1, 0, 1, 0)

		local SideZeroColumn = ColumnsData[0].Instance
		local sideZeroLayout = SideZeroColumn:FindFirstChildOfClass("UIListLayout")

		local ColumnRow = Instances:Create("Frame", {
			Parent = ParentInstance,
			Name = "\0",
			Size = UDim2New(1, 0, 1, 0),
			Position = UDim2New(0, 0, 0, 0),
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			ClipsDescendants = true,
			ZIndex = 2,
		})

		for Index = 1, 2 do
			ColumnsData[Index] = CreateSectionColumn(ColumnRow.Instance)
		end

		local function UpdateStackLayout()
			local parentHeight = ParentInstance.AbsoluteSize.Y
			local layoutHeight = sideZeroLayout and sideZeroLayout.AbsoluteContentSize.Y or 0

			if layoutHeight <= 0 then
				SideZeroWrapper.Instance.Size = UDim2New(1, 0, 0, 0)
				SideZeroColumn.ScrollingEnabled = false
				ColumnRow.Instance.Position = UDim2New(0, 0, 0, 0)
				ColumnRow.Instance.Size = UDim2New(1, 0, 1, 0)
				return
			end

			local displayHeight = layoutHeight

			if layoutHeight + MIN_COLUMN_VIEW_HEIGHT + COLUMN_GAP > parentHeight then
				displayHeight = math.max(80, parentHeight - MIN_COLUMN_VIEW_HEIGHT - COLUMN_GAP)
			end

			local scrollSideZero = layoutHeight > displayHeight + 1

			SideZeroWrapper.Instance.Size = UDim2New(1, 0, 0, displayHeight)
			SideZeroColumn.Size = UDim2New(1, 0, 1, 0)
			SideZeroColumn.ScrollingEnabled = scrollSideZero

			ColumnRow.Instance.Position = UDim2New(0, 0, 0, displayHeight)
			ColumnRow.Instance.Size = UDim2New(1, 0, 1, -displayHeight)
		end

		if sideZeroLayout then
			sideZeroLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(UpdateStackLayout)
		end

		SideZeroWrapper.Instance:GetPropertyChangedSignal("AbsoluteSize"):Connect(UpdateStackLayout)
		ParentInstance:GetPropertyChangedSignal("AbsoluteSize"):Connect(UpdateStackLayout)

		local UpdateColumns = BindTwoColumnLayout(ColumnRow.Instance, ColumnsData)

		local function UpdateLayout()
			UpdateStackLayout()
			UpdateColumns()
		end

		defer(UpdateLayout)
		task.delay(0.05, UpdateLayout)

		return UpdateLayout, ColumnRow
	end

