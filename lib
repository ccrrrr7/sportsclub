		Instances.Tween = function(self, Info, Goal)
			if not self.Instance then
				return
			end

			if not Library then
				return
			end

			if Library:ShouldSkipVisualTween() and type(Goal) == "table" then
				Library:ApplyTweenGoals(self.Instance, Goal)
				return
			end

			return Tween:Create(self, Info, Goal)
		end

		Instances.IsMouseOverFrame = function(self)
			if not self.Instance then
				return false
			end

			local Object = self.Instance
			local MousePosition = Vector2New(Mouse.X, Mouse.Y)

			return MousePosition.X >= Object.AbsolutePosition.X
				and MousePosition.X <= Object.AbsolutePosition.X + Object.AbsoluteSize.X
				and MousePosition.Y >= Object.AbsolutePosition.Y
				and MousePosition.Y <= Object.AbsolutePosition.Y + Object.AbsoluteSize.Y
		end

		Instances.FadeDescendants = function(self, Visibility, Callback)
			if not self.Instance then
				if Callback then
					Callback()
				end
				return
			end

			if Visibility then
				self.Instance.Visible = true
			end

			local NewTween
			local Children = self.Instance:GetDescendants()

			TableInsert(Children, self.Instance)

			for _, Child in Children do
				local TransparencyProperty = Tween:GetProperty(Child)

				if not TransparencyProperty then
					continue
				end

				if type(TransparencyProperty) == "table" then
					for _, Property in TransparencyProperty do
						NewTween = Tween:FadeItem(Child, Property, Visibility, Library.FadeSpeed)
					end
				else
					NewTween = Tween:FadeItem(Child, TransparencyProperty, Visibility, Library.FadeSpeed)
				end
			end

			local function Finish()
				if Callback then
					Callback()
				end

				self.Instance.Visible = Visibility
			end

			if NewTween and NewTween.Tween then
				Library:Connect(NewTween.Tween.Completed, Finish)
			else
				Finish()
			end
		end

		Instances.Disconnect = function(self, Name)
