	local FontsFolder = GetAssetsFontsFolder()

	local function IsValidFontBytes(Data)
		if type(Data) ~= "string" or #Data < 12 then
			return false
		end

		if Data:sub(1, 1) == "<" then
			return false
		end

		local Sig = Data:sub(1, 4)

		return Sig == "\0\1\0\0" or Sig == "OTTO" or Sig == "true" or Sig == "wOFF" or Sig == "ttcf"
	end

	local function RegisterFont(Name, Weight, Style, TtfFile, Url)
		local TtfPath = FontsFolder .. "/" .. TtfFile

		if isfile(TtfPath) then
			local CachedBytes = readfile(TtfPath)

			if not IsValidFontBytes(CachedBytes) then
				pcall(delfile, TtfPath)
				pcall(delfile, FontsFolder .. "/" .. Name .. ".font")
			end
		end

		if not isfile(TtfPath) then
			local DownloadSuccess, Downloaded = pcall(game.HttpGet, game, Url)

			if not DownloadSuccess or not IsValidFontBytes(Downloaded) then
				return nil
			end

			writefile(TtfPath, Downloaded)
		end

		local FontMetaPath = FontsFolder .. "/" .. Name .. ".font"

		if isfile(FontMetaPath) then
			local CachedAssetSuccess, CachedFontAssetId = pcall(getcustomasset, FontMetaPath)
			if CachedAssetSuccess and type(CachedFontAssetId) == "string" and CachedFontAssetId ~= "" then
				return CachedFontAssetId
			end
		end

		local AssetSuccess, AssetId = pcall(getcustomasset, TtfPath)

		if not AssetSuccess then
			return nil
		end

		local FontData = {
			name = Name,
			faces = {
				{
					name = "Regular",
					weight = Weight,
					style = Style,
					assetId = AssetId,
				},
			},
		}

		if isfile(FontMetaPath) then
			pcall(delfile, FontMetaPath)
		end

		writefile(FontMetaPath, HttpService:JSONEncode(FontData))

		local FontAssetSuccess, FontAssetId = pcall(getcustomasset, FontMetaPath)

		if not FontAssetSuccess then
			return nil
		end

		return FontAssetId
	end

	local function PeekLocalSettings()
		local SettingsPath = GetLocalSettingsPath()

		if not isfile(SettingsPath) then
			return nil
		end

		local Success, Decoded = pcall(function()
			return HttpService:JSONDecode(readfile(SettingsPath))
		end)

		if Success and type(Decoded) == "table" then
			return Decoded
		end

		return nil
	end

	local function ApplyAutoloadThemeColorsEarly(Settings)
		if type(Settings) == "table" and Settings.AutoloadThemeEnabled == false then
			return
		end

		if type(Settings) == "table" and Settings.AutoloadThemeEnabled ~= true then
			return
		end

		local ThemeNamePath = GetAutoloadThemeNamePath()

		if not isfile(ThemeNamePath) then
			return
		end

		local ThemeName = readfile(ThemeNamePath)

		if type(ThemeName) ~= "string" or ThemeName == "" then
			return
		end

		local ThemePath = GetFolders().Themes .. "/" .. ThemeName .. ".json"

		if not isfile(ThemePath) then
			return
		end

		local DecodeSuccess, Decoded = pcall(function()
			return HttpService:JSONDecode(readfile(ThemePath))
		end)

		if not DecodeSuccess or type(Decoded) ~= "table" then
			return
		end

		for Index, Value in Decoded do
			if type(Index) == "string" and Library.Theme[Index] ~= nil and type(Value) == "table" and type(Value.Color) == "string" then
				local HexValue = Value.Color

				if HexValue:sub(1, 1) == "#" then
					HexValue = HexValue:sub(2)
				end

				local ColorSuccess, ThemeColor = pcall(FromHex, HexValue)

				if ColorSuccess and typeof(ThemeColor) == "Color3" then
					Library.Theme[Index] = ThemeColor
				end
			end
		end

		Library.AutoloadThemeApplied = true
	end

	local function ApplyLocalPreferenceFieldsEarly(Decoded)
		if type(Decoded) ~= "table" then
			return
		end

		if type(Decoded.SafeMode) == "boolean" then
			Library.SafeMode = Decoded.SafeMode
		end

		if type(Decoded.AutoloadConfigEnabled) == "boolean" then
			Library.AutoloadConfigEnabled = Decoded.AutoloadConfigEnabled
		end

		if type(Decoded.AutoloadThemeEnabled) == "boolean" then
			Library.AutoloadThemeEnabled = Decoded.AutoloadThemeEnabled
		end

		if type(Decoded.BackgroundEffect) == "string" then
			local Effect = Decoded.BackgroundEffect

			if Effect == "Shooting Stars" then
				Effect = "Snow"
			end

			Library.BackgroundEffect = Effect
		elseif Decoded.BackgroundSnowEnabled == false then
			Library.BackgroundEffect = "None"
		elseif Decoded.BackgroundSnowEnabled == true then
			Library.BackgroundEffect = "Snow"
		end

		if Decoded.BackgroundDarkenEnabled == false then
			Library.BackgroundDarkenEnabled = false
		elseif Decoded.BackgroundDarkenEnabled == true then
			Library.BackgroundDarkenEnabled = true
		end

		if type(Decoded.ShowWatermark) == "boolean" then
			Library.ShowWatermark = Decoded.ShowWatermark
		end

		if type(Decoded.ShowKeybindList) == "boolean" then
			Library.ShowKeybindList = Decoded.ShowKeybindList
		end

		if type(Decoded.ShowMenuButton) == "boolean" then
			Library.ShowMenuButton = Decoded.ShowMenuButton
		elseif type(Decoded.ShowFloatingButton) == "boolean" then
			Library.ShowMenuButton = Decoded.ShowFloatingButton
		end

		if type(Decoded.AutoExecute) == "boolean" then
			Library.AutoExecute = Decoded.AutoExecute
		end

		if type(Decoded.LanguagePreset) == "string" and Library.LanguageToCode[Decoded.LanguagePreset] then
			Library.LanguagePreset = Decoded.LanguagePreset
		end

		if type(Decoded.BackgroundTransparency) == "number" then
			Library.BackgroundTransparency = MathClamp(Decoded.BackgroundTransparency, 0, 1)
		end

		if type(Decoded.MenuTweenTime) == "number" then
			Library.Tween.Time = Decoded.MenuTweenTime
		end

		if type(Decoded.MenuFadeTime) == "number" then
			Library.FadeSpeed = Decoded.MenuFadeTime
		end

		if type(Decoded.MenuScalePreset) == "string" then
			Library.MenuScalePreset = Decoded.MenuScalePreset
		end

		if type(Decoded.MenuTweenStyle) == "string" and Enum.EasingStyle[Decoded.MenuTweenStyle] then
			Library.MenuTweenStyle = Decoded.MenuTweenStyle
			Library.Tween.Style = Enum.EasingStyle[Decoded.MenuTweenStyle]
		end

		if type(Decoded.MenuTweenDirection) == "string" and Enum.EasingDirection[Decoded.MenuTweenDirection] then
			Library.MenuTweenDirection = Decoded.MenuTweenDirection
			Library.Tween.Direction = Enum.EasingDirection[Decoded.MenuTweenDirection]
		end

		if type(Decoded.UIMainTextSize) == "number" then
			Library.FontSettings.TextSize = MathClamp(MathFloor(Decoded.UIMainTextSize), 10, 20)
		end

		if type(Decoded.UISmallTextSize) == "number" then
			Library.FontSettings.SmallTextSize = MathClamp(MathFloor(Decoded.UISmallTextSize), 8, 16)
		end

		if type(Decoded.UITitleTextSize) == "number" then
			Library.FontSettings.TitleTextSize = MathClamp(MathFloor(Decoded.UITitleTextSize), 14, 28)
		end
	end

	Library.EnsureFontRegistered = function(self, FontName)
		if type(FontName) ~= "string" or FontName == "" then
			return false
		end

		if self.FontFaces[FontName] then
			return true
		end

		local FontData = self.Fonts[FontName]

		if type(FontData) ~= "table" then
			return false
		end

		local Success, AssetPath = pcall(function()
			return RegisterFont(FontName, FontData.Weight or 200, FontData.Style or "normal", FontData.Id, FontData.Url)
		end)

		if not Success or not AssetPath then
			return false
		end

		local FaceSuccess, Face = pcall(function()
			return Font.new(AssetPath, Enum.FontWeight.Regular, Enum.FontStyle.Normal)
		end)

		if FaceSuccess and Face then
			self.FontFaces[FontName] = Face
			return true
		end

		return false
	end

	Library.RegisterRemainingFontsAsync = function(self)
		task.spawn(function()
			for Name in self.Fonts do
				if not self.FontFaces[Name] then
					self:EnsureFontRegistered(Name)
				end
			end
		end)
	end

	do
		local SavedSettings = PeekLocalSettings()

		ApplyAutoloadThemeColorsEarly(SavedSettings)
		ApplyLocalPreferenceFieldsEarly(SavedSettings)

		local PreferredFont = (SavedSettings and type(SavedSettings.UIFont) == "string" and SavedSettings.UIFont) or Library.FontSettings.Name

		Library:EnsureFontRegistered("Made Bold")
		Library:EnsureFontRegistered("Inter")
		if PreferredFont ~= "Made Bold" and PreferredFont ~= "Inter" then
			Library:EnsureFontRegistered(PreferredFont)
		end

		if Library.FontFaces[PreferredFont] then
			Library.FontSettings.Name = PreferredFont
			Library.Font = Library.FontFaces[PreferredFont]
		else
			Library.Font = Library.FontFaces[Library.FontSettings.Name] or Library.FontFaces.Inter or Font.fromEnum(Enum.Font.Gotham)
		end

		Library.PreferencesBootstrapped = true
		Library:RegisterRemainingFontsAsync()
	end

