    function library:load_config(config_json)
        local ok, decoded = pcall(function()
            return http_service:JSONDecode(config_json)
        end)

        if not ok or type(decoded) ~= "table" then
            return
        end

        local success, err = pcall(function()
            local objects = decoded.objects

            if type(objects) == "table" then
                for _, object_data in ipairs(objects) do
                    if object_data and object_data.idx and object_data.type then
                        if object_data.type == "ColorPicker" then
                            library:apply_config_flag(object_data.idx, object_data, "ColorPicker")
                        elseif object_data.type == "KeyPicker" then
                            library:apply_config_flag(object_data.idx, {
                                mode = object_data.mode,
                                key = object_data.key,
                                active = object_data.active,
                            }, "KeyPicker")
                        elseif object_data.type == "Input" then
                            library:apply_config_flag(object_data.idx, object_data.text, "Input")
                        else
                            library:apply_config_flag(object_data.idx, object_data.value, object_data.type)
                        end
                    end
                end

                library:run_config_finalize()
                return
            end

            -- fallback: support legacy flat config format (old_lib.lua style)
            for flag_name, value in pairs(decoded) do
                if flag_name == "objects" then
                    continue
                end

                local function_set = library.config_flags[flag_name]
                if not function_set then
                    continue
                end

                if type(value) == "table" and (value.Transparency ~= nil and value.Color ~= nil) then
                    local ok_color, color_val = pcall(function()
                        return library:coerce_color_value(value.Color)
                    end)

                    if ok_color and color_val then
                        pcall(function_set, color_val, tonumber(value.Transparency) or tonumber(value.transparency) or 0)
                    end
                elseif type(value) == "table" and (value.mode ~= nil or value.key ~= nil or value.active ~= nil) then
                    local key_value = value.key
                    if type(key_value) == "string" and key_value ~= "NONE" and tostring(key_value):find("Enum", 1, true) then
                        key_value = library:convert_enum(key_value)
                    end

                    pcall(function_set, {
                        mode = value.mode,
                        key = key_value,
                        active = value.active,
                    })
                else
                    pcall(function_set, value)
                end
            end

            library:run_config_finalize()
        end)

        if not success then
            warn("load_config failed:", err)
        end
    end
    
    function library:round(number, float) 
        if typeof(number) ~= "number" then
            warn("rounding got non-number:", number, typeof(number))
            return 0
        end

        if float ~= nil and typeof(float) ~= "number" then
            warn("rounding got invalid float:", float, typeof(float))
            float = 1
        end

        local multiplier = 1 / (float or 1)

        return math.floor(number * multiplier + 0.5) / multiplier
    end

    function library:apply_theme(instance, theme, property) 
        insert(themes.utility[theme][property], instance)
    end

    function library:update_theme(theme, color)
        for property_name, property in themes.utility[theme] do 
            for _, object in property do 
                if object and object.Parent then
                    object[property_name] = color
                end
            end 
        end 

        themes.preset[theme] = color 
    end 

    function library:connection(signal, callback)
        local connection = signal:Connect(callback)
        
        insert(library.connections, connection)

        return connection 
    end

    function library:close_element(new_path) 
        local open_element = library.current_open

        if open_element and new_path ~= open_element then
            open_element.set_visible(false)
            open_element.open = false;
        end 

        if new_path ~= open_element then 
            library.current_open = new_path or nil;
        end
    end 

    function library:create(instance, options)
        local parent = options.Parent
        local ins = Instance.new(instance)

        for prop, value in options do
            if prop ~= "Parent" then
                ins[prop] = value
            end
        end

        if parent then
            ins.Parent = parent
        end

        return ins
    end

    function library:set(instance, property, value)
        if not instance then
            return
        end
        task.defer(function()
            pcall(function()
                instance[property] = value
            end)
        end)
    end

    function library:get_icon(icon_name)
        if library.icon_cache == false then
            return nil
        end

        if not library.icon_cache then
            local success, module = pcall(function()
                return (loadstring(game:HttpGet("https://raw.githubusercontent.com/deividcomsono/lucide-roblox-direct/refs/heads/main/source.lua"))())
            end)

            library.icon_cache = success and module or false
        end

        if library.icon_cache == false or not library.icon_cache.GetAsset then
            return nil
        end

        local ok, icon = pcall(library.icon_cache.GetAsset, library.icon_cache, icon_name)
        return ok and icon or nil
    end

    function library:unload_menu() 
        library.unloading = true

        for index, connection in library.connections do
            pcall(function()
                connection:Disconnect()
            end)
            library.connections[index] = nil
        end

        if library[ "items" ] then 
            library[ "items" ]:Destroy()
        end

        if library[ "other" ] then 
            library[ "other" ]:Destroy()
        end 

        for _, theme_data in pairs(themes.utility) do
            for property_name in pairs(theme_data) do
                theme_data[property_name] = {}
            end
        end

        library.current_open = nil
        library = nil 
    end 
