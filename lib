                TextScaled = true;
                Size = dim2(1, -2, 1, -2);
                Position = dim2(0, 1, 0, uis.TouchEnabled and -3 or -1);
            })
        end

        local resizing = false 
        local start_size 
        local start 
        local og_size = frame.Size  

        library:connection(Frame.InputBegan, function(input)
            if library:is_size_locked() then
                return
            end

            if library:is_primary_input(input) then
                resizing = true
                start = input.Position
                start_size = frame.Size
            end
        end)

        library:connection(Frame.InputEnded, function(input)
            if library:is_primary_input(input) then
                resizing = false
            end
        end)

        library:connection(uis.InputChanged, function(input, game_event) 
            if library:is_size_locked() then
                return
            end

            if resizing and library:is_pointer_movement(input) then
                local viewport_x = camera.ViewportSize.X
                local viewport_y = camera.ViewportSize.Y
                local min_window_size = library:get_min_window_size()
                local min_pad = library:is_mobile() and 40 or 0
                local min_w = math.max(min_window_size.X, og_size.X.Offset)
                local min_h = math.max(min_window_size.Y, og_size.Y.Offset)

                local current_size = dim2(
                    start_size.X.Scale,
                    clamp(
                        start_size.X.Offset + (input.Position.X - start.X),
                        min_w,
                        viewport_x - frame.Position.X.Offset - min_pad
                    ),
                    start_size.Y.Scale,
                    clamp(
                        start_size.Y.Offset + (input.Position.Y - start.Y),
                        min_h,
                        viewport_y - frame.Position.Y.Offset - min_pad
                    )
                )

                frame.Size = current_size
                library:fit_to_viewport(frame)
            end
        end)
    end 

    function fag(tbl)
        local Size = 0
        
        for _ in tbl do
            Size = Size + 1
        end
    
        return Size
    end
    
    function library:next_flag()
