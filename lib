                end
            end,
        },
        Dropdown = {
            Save = function(idx, object)
                return { type = "Dropdown", idx = idx, value = object.Value, multi = object.Multi }
            end,
            Load = function(idx, data)
                local object = library.Options[idx]
                if object and object.SetValue and data.value ~= nil then
                    object:SetValue(data.value)
                end
            end,
        },
        ColorPicker = {
            Save = function(idx, object)
                local color_value = object.Value
                if typeof(color_value) ~= "Color3" and type(color_value) == "table" then
                    color_value = color_value.Color
                end

                if typeof(color_value) ~= "Color3" then
                    return nil
                end

                return {
                    type = "ColorPicker",
                    idx = idx,
                    value = color_value:ToHex():gsub("^#", ""),
                    transparency = tonumber(object.Transparency) or 0,
                }
            end,
            Load = function(idx, data)
                local object = library.Options[idx]
                if not object or not object.SetValueRGB then
                    return
                end

                local color_value = library:coerce_color_value(data.value)
                if not color_value and type(data.value) == "table" then
                    color_value = library:coerce_color_value(data.value.Color or data.value)
                end

                if color_value then
                    object:SetValueRGB(color_value, tonumber(data.transparency) or 0)
                end
            end,
        },
        KeyPicker = {
            Save = function(idx, object)
                return { type = "KeyPicker", idx = idx, mode = object.Mode, key = tostring(object.Value), active = object.Active }
            end,
            Load = function(idx, data)
                local object = library.Options[idx]
                if object and object.SetValue then
                    local key_value = data.key
                    if type(key_value) == "string" and key_value ~= "NONE" and tostring(key_value):find("Enum", 1, true) then
                        key_value = library:convert_enum(key_value)
                    end

                    object:SetValue({
                        mode = data.mode,
                        key = key_value,
                        active = data.active
                    })
                end
            end,
        },
        Input = {
            Save = function(idx, object)
                return { type = "Input", idx = idx, text = object.Value }
            end,
            Load = function(idx, data)
                local object = library.Options[idx]
                if object and object.SetValue and type(data.text) == "string" and object.Value ~= data.text then
                    object:SetValue(data.text)
                end
