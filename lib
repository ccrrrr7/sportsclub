            });
            
            return button
        end

        local function get_visible_option_count()
            local visible = 0
            for _, option in cfg.option_instances do
                if option.Visible then
                    visible += 1
                end
            end

            return visible
        end

        local function apply_search_filter(query)
            local normalized = string.lower(query or "")

            for _, option in cfg.option_instances do
                if normalized == "" then
                    option.Visible = true
                else
                    option.Visible = string.find(string.lower(option.Text), normalized, 1, true) ~= nil
                end
            end
        end
        
        function cfg.set_visible(bool)
            items[ "dropdown_holder" ].Visible = bool

            local visible_count = get_visible_option_count()
            local max_visible_rows = 7
            local row_height = 21
            local use_scroll = visible_count > max_visible_rows
            local render_rows = min(visible_count, max_visible_rows)
            local a = bool and ((render_rows * row_height) + 12) or 0

            items[ "list_scroller" ].ScrollBarThickness = use_scroll and 3 or 0
            library:tween(items[ "dropdown_holder" ], {Size = dim_offset(items[ "dropdown" ].AbsoluteSize.X, a)})

            items[ "dropdown_holder" ].Position = dim2(0, items[ "dropdown" ].AbsolutePosition.X, 0, items[ "dropdown" ].AbsolutePosition.Y + 80)
            if not (self.sanity and library.current_open == self) then 
                library:close_element(cfg)
            end

            if cfg.searchable and items[ "search_box" ] then
                if bool then
                    items[ "sub_text" ].Visible = false
                    items[ "search_box" ].Visible = true
                    items[ "search_box" ].Text = ""
                    apply_search_filter("")
                    items[ "search_box" ]:CaptureFocus()
                else
                    items[ "search_box" ].Text = ""
                    items[ "search_box" ].Visible = false
                    items[ "search_box" ]:ReleaseFocus()
                    items[ "sub_text" ].Visible = true
                    apply_search_filter("")
                end
            end
        end
        
        function cfg.set(value)
            if value == nil then
                return
            end

            local is_table = type(value) == "table"
            if is_table then
                if cfg.multi then
                    local normalized = {}
                    for _, entry in ipairs(value) do
                        if type(entry) == "string" and entry ~= "" then
                            insert(normalized, entry)
                        end
                    end
                    value = normalized
                else
                    value = value[1] or value.value or value.Value
                    if type(value) ~= "string" then
                        return
                    end
                    is_table = false
                end
            elseif type(value) ~= "string" then
                return
            end

            local selected = {}
            local is_multi_table = type(value) == "table"

            for _, option in cfg.option_instances do 
                if option.Text == value or (is_multi_table and find(value, option.Text)) then 
                    insert(selected, option.Text)
                    cfg.multi_items = selected
                    option.TextColor3 = themes.preset.accent
                else
                    option.TextColor3 = rgb(72, 72, 73)
                end
            end

            local display_text = is_multi_table and concat(selected, ", ") or (selected[1] or "")
            if type(display_text) ~= "string" then
                display_text = tostring(display_text or "")
            end

            items[ "sub_text" ].Text = display_text
            flags[cfg.flag] = is_multi_table and selected or selected[1]
            cfg.Value = flags[cfg.flag]
            cfg.callback(flags[cfg.flag]) 
        end
        
        function cfg.refresh_options(list) 
            cfg.options = list
            cfg.y_size = 0

            for _, option in cfg.option_instances do 
                option:Destroy() 
            end
            
            cfg.option_instances = {} 

            for _, option in list do 
                local button = cfg.render_option(option)
                cfg.y_size += button.AbsoluteSize.Y + 6 -- super annoying manual sizing but oh well
                insert(cfg.option_instances, button)
                
                library:connection(button.MouseButton1Down, function()
                    if cfg.multi then 
                        local selected_index = find(cfg.multi_items, button.Text)
                        
                        if selected_index then 
                            remove(cfg.multi_items, selected_index)
                        else
                            insert(cfg.multi_items, button.Text)
                        end
                        
                        cfg.set(cfg.multi_items) 				
                    else 
                        cfg.set_visible(false)
                        cfg.open = false 
                        
                        cfg.set(button.Text)
                    end
                end)
            end

            if cfg.searchable and items[ "search_box" ] and items[ "search_box" ].Visible then
                apply_search_filter(items[ "search_box" ].Text)
            else
                apply_search_filter("")
            end
        end

        library:connection(items[ "dropdown" ].MouseButton1Click, function()
            cfg.open = not cfg.open 
            
            cfg.set_visible(cfg.open)
        end)

        if cfg.searchable and items[ "search_box" ] then
            library:connection(items[ "search_box" ]:GetPropertyChangedSignal("Text"), function()
                apply_search_filter(items[ "search_box" ].Text)
                if cfg.open then
                    local visible_count = get_visible_option_count()
                    local render_rows = min(visible_count, 7)
                    local a = (render_rows * 21) + 12
                    items[ "list_scroller" ].ScrollBarThickness = visible_count > 7 and 3 or 0
                    items[ "dropdown_holder" ].Size = dim_offset(items[ "dropdown" ].AbsoluteSize.X, a)
                end
            end)
        end

        library:connection(uis.InputBegan, function(input)
            if not library:is_primary_input(input) or not cfg.open then
                return
            end

            local mx, my = mouse.X, mouse.Y
            local holder_pos, holder_size = items[ "dropdown_holder" ].AbsolutePosition, items[ "dropdown_holder" ].AbsoluteSize
            local dropdown_pos, dropdown_size = items[ "dropdown" ].AbsolutePosition, items[ "dropdown" ].AbsoluteSize

            local inside_holder = mx >= holder_pos.X and mx <= holder_pos.X + holder_size.X and my >= holder_pos.Y and my <= holder_pos.Y + holder_size.Y
            local inside_dropdown = mx >= dropdown_pos.X and mx <= dropdown_pos.X + dropdown_size.X and my >= dropdown_pos.Y and my <= dropdown_pos.Y + dropdown_size.Y

            if not inside_holder and not inside_dropdown then
                cfg.set_visible(false)
                cfg.open = false
            end
        end)

        if cfg.seperator then 
            library:create( "Frame" , {
                AnchorPoint = vec2(0, 1);
                Parent = self.items[ "elements" ];
                Position = dim2(0, 0, 1, 0);
                BorderColor3 = rgb(0, 0, 0);
                Size = dim2(1, 1, 0, 1);
                BorderSizePixel = 0;
                BackgroundColor3 = rgb(36, 36, 37)
            });
        end 

        flags[cfg.flag] = {} 
        cfg.Type = "Dropdown"
        cfg.Multi = cfg.multi
        cfg.Value = nil
        cfg.SetValue = cfg.set
        library.Options[cfg.flag] = cfg
        config_flags[cfg.flag] = cfg.set
        
        cfg.refresh_options(cfg.options)
        cfg.set(cfg.default)

        if cfg.search_context and cfg.search_context.tab and cfg.name then
            library:register_search_feature(cfg.search_context.tab, {
                kind = "control";
                text = cfg.name;
                info = cfg.info;
                page = cfg.search_context.page;
                page_name = cfg.search_context.page_name;
                section_name = cfg.search_context.section_name;
                holder = items["dropdown_object"];
                section_outline = cfg.search_context.section_outline;
                parent_control = cfg.search_context.parent_control;
            })
        end
            
        return setmetatable(cfg, library)
    end

