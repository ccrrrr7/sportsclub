        local accel_smoothness = sportsclub_settings["AutoParryAccelerationSmoothness"]
        local last_forward_accel = 0
        local last_lateral_accel = 0
        local dist_flip_count = 0

        for offset = count - 1, 1, -1 do
            local current_index = ((history.index - offset - 1 + history.size) % history.size) + 1
            local next_index = ((current_index) % history.size) + 1
            local dt = math_max(history.time[next_index] - history.time[current_index], 0.008)
            local vel_x = history.vel_x[current_index]
            local vel_y = history.vel_y[current_index]
            local vel_z = history.vel_z[current_index]
            local next_vel_x = history.vel_x[next_index]
            local next_vel_y = history.vel_y[next_index]
            local next_vel_z = history.vel_z[next_index]
            local vel_mag = math_sqrt(vel_x * vel_x + vel_y * vel_y + vel_z * vel_z)
            local next_vel_mag = math_sqrt(next_vel_x * next_vel_x + next_vel_y * next_vel_y + next_vel_z * next_vel_z)
            local accel_x = (next_vel_x - vel_x) / dt
            local accel_y = (next_vel_y - vel_y) / dt
            local accel_z = (next_vel_z - vel_z) / dt
            local accel_mag = math_sqrt(accel_x * accel_x + accel_y * accel_y + accel_z * accel_z)

            accel_sum = accel_sum + accel_mag
            accel_count = accel_count + 1
            accel_sum_x = accel_sum_x + accel_x
            accel_sum_y = accel_sum_y + accel_y
            accel_sum_z = accel_sum_z + accel_z

            local current_dot = history.dot[next_index]
            dot_swing = math_max(dot_swing, abs(current_dot - last_dot))
            dot_trend = dot_trend + (current_dot - last_dot)
            last_dot = current_dot

            local current_dist_delta = history.dist[current_index] - history.dist[next_index]
            distance_trend = distance_trend + current_dist_delta
            closeness_trend = closeness_trend + current_dist_delta / math_max(history.dist[current_index], 1)
            if last_dist_delta and current_dist_delta * last_dist_delta < 0 then
                dist_flip_count = dist_flip_count + 1
            end
            last_dist_delta = current_dist_delta

            local heading = math_atan2(next_vel_z, next_vel_x)
            if last_heading then
                local heading_delta = abs(heading - last_heading)
                if heading_delta > pi then
                    heading_delta = (2 * pi) - heading_delta
                end
                heading_rotation = heading_rotation + heading_delta
            end
            last_heading = heading

            if vel_mag > 0.001 and next_vel_mag > 0.001 then
                local unit_dot = math_clamp(((vel_x * next_vel_x) + (vel_y * next_vel_y) + (vel_z * next_vel_z)) / (vel_mag * next_vel_mag), -1, 1)
                local direction_angle = math_deg(math_acos(unit_dot))
