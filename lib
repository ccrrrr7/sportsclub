sportsclub_functions.safe_hook = function(tbl, key, fn)
    if type(hookfunction) ~= "function" then return false end
    local target = nil
    if type(tbl) == "function" then
        target = tbl
    elseif type(tbl) == "table" and key and tbl[key] then
        target = tbl[key]
    end
    if type(target) ~= "function" then return false end
    return pcall(hookfunction, target, fn)
end

