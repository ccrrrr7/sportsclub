        predicted_curve_confidence = predicted_curve_confidence + closeness_score * 0.14
        predicted_curve_confidence = predicted_curve_confidence + closing_score * 0.1
        predicted_curve_confidence = predicted_curve_confidence + curve_strength * 0.15
        predicted_curve_confidence = predicted_curve_confidence + eta_stability * 0.08
        if direction_changed_recently then
