		local function SpawnSnow(Effects, Holder, Width, Height)
			local Image = InstanceNew("ImageLabel")
			Image.Name = "\0"
			Image.Parent = Holder
			Image.BackgroundTransparency = 1
			Image.Image = Effects.SnowAsset
			Image.ImageTransparency = 0.15
			Image.ZIndex = 0

