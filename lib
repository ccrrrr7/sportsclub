	local function GetMobileUIScale(Percent)
		Percent = MathClamp(tonumber(Percent) or 1, 0.5, 1.1)
		local Viewport = ViewportSize()
		local DesignWidth = Library.UIScaleDesignSize.X
		local DesignHeight = 526 * (Library.MobileFrameHeightScale or 0.85)
		local HeightPercent = Library.MobileScaleHeightPercent or 0.48
		local WidthPercent = Library.MobileScaleWidthPercent or 0.61
		local ScaleHeight = (Viewport.Y * HeightPercent * Percent) / DesignHeight
		local ScaleWidth = (Viewport.X * WidthPercent * Percent) / DesignWidth
		return MathClamp(math.min(ScaleHeight, ScaleWidth), 0.75, 2.2)
	end

	function Library:ApplyMobileFrameSize()
		if not IsMobile or not self.MainWindowFrame then return end
		local frame_height = MathFloor(526 * (self.MobileFrameHeightScale or 0.85))
		self.MainWindowFrame.Size = UDim2.fromOffset(self.UIScaleDesignSize.X, frame_height)
	end

	function Library:SetScaleFromScreenPercent(Percent)
		Percent = MathClamp(Percent, 0.2, 1)

		self.UIScaleScreenPercent = Percent

		local DesignWidth, DesignHeight = self.UIScaleDesignSize.X, self.UIScaleDesignSize.Y
		local Scale

		if IsMobile then
			Scale = GetMobileUIScale(Percent)
		else
			local Viewport = ViewportSize()
			local TargetWidth = math.min(DesignWidth, Viewport.X * Percent)
			local TargetHeight = math.min(DesignHeight, Viewport.Y * Percent)

			local ScaleWidth = TargetWidth / DesignWidth
			local ScaleHeight = TargetHeight / DesignHeight

			Scale = math.min(ScaleWidth, ScaleHeight)
			Scale = MathClamp(Scale, 0.5, 1.2)
		end

		self.UIScaleObject.Instance.Scale = Scale
		self.UIScaleNum = Scale
		if IsMobile then self:ApplyMobileFrameSize() end
	end

	function Library:SetScaleNumeric(Value)
		Value = MathClamp(Value, 300, 1400)

		self.UIScaleNumeric = Value
		self.UIScaleScreenPercent = Value / 1400

		local Scale

		if IsMobile then
			Scale = GetMobileUIScale(MobileScalePercents[Value] or 1)
		else
			local Viewport = ViewportSize()
			Scale = Viewport.Y / Value
			Scale = MathClamp(Scale, 0.3, 3)
		end

		self.UIScaleObject.Instance.Scale = Scale
		self.UIScaleNum = Scale
		if IsMobile then self:ApplyMobileFrameSize() end
	end

	if IsMobile then
		Library:SetScaleFromScreenPercent(Library.UIScaleScreenPercent)
	else
		Library:SetScaleNumeric(ScaleValues[Library.MenuScalePreset] or 1000)
	end

