    function library:normalize_flag_name(value)
        local normalized_value = tostring(value or ""):lower()
        normalized_value = normalized_value:gsub("[^%w]+", "_"):gsub("^_+", ""):gsub("_+$", "")
        return normalized_value ~= "" and normalized_value or nil
    end

    function library:get_control_flag(scope_name, control_name, control_type, explicit_flag)
        if explicit_flag then
            return explicit_flag
        end

        local normalized_scope = library:normalize_flag_name(scope_name)
        local normalized_control = library:normalize_flag_name(control_name)
        local normalized_type = library:normalize_flag_name(control_type) or "control"

        if normalized_scope and normalized_control then
            return normalized_scope .. "_" .. normalized_control .. "_" .. normalized_type
        end

        if normalized_control then
            return normalized_control .. "_" .. normalized_type
        end

        if normalized_scope then
            return normalized_scope .. "_" .. normalized_type
        end

        return library:next_flag()
    end

    function library:mouse_in_frame(uiobject)
        local y_cond = uiobject.AbsolutePosition.Y <= mouse.Y and mouse.Y <= uiobject.AbsolutePosition.Y + uiobject.AbsoluteSize.Y
        local x_cond = uiobject.AbsolutePosition.X <= mouse.X and mouse.X <= uiobject.AbsolutePosition.X + uiobject.AbsoluteSize.X

        return (y_cond and x_cond)
    end

    function library:point_in_frame(uiobject, point)
        if not uiobject or not point then
            return false
        end

        local y_cond = uiobject.AbsolutePosition.Y <= point.Y and point.Y <= uiobject.AbsolutePosition.Y + uiobject.AbsoluteSize.Y
        local x_cond = uiobject.AbsolutePosition.X <= point.X and point.X <= uiobject.AbsolutePosition.X + uiobject.AbsoluteSize.X

        return y_cond and x_cond
    end

