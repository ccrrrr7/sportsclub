    function library:apply_config_flag(flag_name, value, object_type)
        if not flag_name or library.config_ignore[flag_name] then
            return false
        end

        local function_set = library.config_flags[flag_name]
        if not function_set then
            return false
        end

        if object_type == "ColorPicker" then
            local color_value = library:coerce_color_value(value.value)
            if not color_value and type(value) == "table" then
                color_value = library:coerce_color_value(value.Color)
            end

            if color_value then
                pcall(function_set, color_value, tonumber(value.transparency) or tonumber(value.Transparency) or 0)
                return true
            end

            return false
        end

        if object_type == "KeyPicker" then
            local key_value = value.key
            if type(key_value) == "string" and key_value ~= "NONE" and tostring(key_value):find("Enum", 1, true) then
                key_value = library:convert_enum(key_value)
            end

            pcall(function_set, {
                mode = value.mode,
                key = key_value,
                active = value.active,
            })
            return true
        end

        if object_type == "Input" then
            if type(value) == "string" then
                pcall(function_set, value)
                return true
            end

            return false
        end

        if type(value) == "table" and (value.Color ~= nil or value.color ~= nil) and (value.Transparency ~= nil or value.transparency ~= nil) then
            local color_value = library:coerce_color_value(value.Color or value.color)
            if color_value then
                pcall(function_set, color_value, tonumber(value.Transparency) or tonumber(value.transparency) or 0)
                return true
            end

            return false
        end

        if type(value) == "table" and (value.mode ~= nil or value.key ~= nil or value.active ~= nil) then
            local key_value = value.key
            if type(key_value) == "string" and key_value ~= "NONE" and tostring(key_value):find("Enum", 1, true) then
                key_value = library:convert_enum(key_value)
            end

            pcall(function_set, {
                mode = value.mode,
                key = key_value,
                active = value.active,
            })
            return true
        end

        if value ~= nil then
            pcall(function_set, value)
            return true
        end

        return false
    end

