        local avg_accel = accel_count > 0 and (accel_sum / accel_count) or 0
        local avg_accel_x = accel_count > 0 and (accel_sum_x / accel_count) or 0
        local avg_accel_y = accel_count > 0 and (accel_sum_y / accel_count) or 0
        local avg_accel_z = accel_count > 0 and (accel_sum_z / accel_count) or 0
        local forward_accel = weighted_samples > 0 and smooth_forward_accel or 0
        local lateral_accel = weighted_samples > 0 and smooth_lateral_accel or 0
        local avg_eta = eta_count > 0 and (eta_sum / eta_count) or math_huge

