    function library:coerce_toggle_value(value)
        if type(value) == "boolean" then
            return value
        end

        if type(value) == "string" then
            local lowered = string.lower(value)
            return lowered == "true" or lowered == "1"
        end

        if type(value) == "number" then
            return value ~= 0
        end

        return false
    end

    function library:coerce_color_value(value)
        if typeof(value) == "Color3" then
            return value
        end

        if type(value) == "string" and value ~= "" then
            local hex_string = value:gsub("^#", "")
            if #hex_string == 6 or #hex_string == 8 then
                local success, color_value = pcall(hex, "#" .. hex_string:sub(1, 6))
                if success and typeof(color_value) == "Color3" then
                    return color_value
                end

                local red_value = tonumber(hex_string:sub(1, 2), 16)
                local green_value = tonumber(hex_string:sub(3, 4), 16)
                local blue_value = tonumber(hex_string:sub(5, 6), 16)
                if red_value and green_value and blue_value then
                    return rgb(red_value, green_value, blue_value)
                end
            end
        end

        if type(value) == "table" then
            if typeof(value.Color) == "Color3" then
                return value.Color
            end

            if type(value.Color) == "string" and value.Color ~= "" then
                local success, color_value = pcall(hex, tostring(value.Color):gsub("^#", ""))
                if success then
                    return color_value
                end
            end

            local red_value = tonumber(value.R or value.r or value[1])
            local green_value = tonumber(value.G or value.g or value[2])
            local blue_value = tonumber(value.B or value.b or value[3])
            if red_value and green_value and blue_value then
                if red_value <= 1 and green_value <= 1 and blue_value <= 1 then
                    return color(red_value, green_value, blue_value)
                end

                return rgb(red_value, green_value, blue_value)
            end
        end

        return nil
    end

