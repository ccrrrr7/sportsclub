				end)
			end,
		})

		return Section
	end

	Library.CreateServersPage = function(self, Window)
		local Page = Window:Page({ Name = "Servers", Columns = 2 })
		local Root = Page.Items["Columns"].Instance

		local TeleportService = cloneref(game:GetService("TeleportService"))
		local HttpService = cloneref(game:GetService("HttpService"))

		local Columns = {
			{ Title = "SERVER", X = 0.02, W = 0.34 },
			{ Title = "PLAYERS", X = 0.40, W = 0.22 },
			{ Title = "PING", X = 0.63, W = 0.18 },
			{ Title = "FPS", X = 0.82, W = 0.16 },
		}

		local PerPage = 50
		local ROW_HEIGHT = 26
		local AllServers = {}
		local SelectedId = nil
		local CurrentPage = 1
		local Fetching = false
		local Rows = {}
		local PageLabel

		local function Notify(Message, Color)
			Library:Notification({ Name = "Servers", Description = Message, Color = Color or FromRGB(120, 255, 120), Duration = 3 })
		end

		local function HttpGet(Url)
			local ok, body = RunWithThreadIdentity(8, function()
				if type(game.HttpGet) == "function" then return game:HttpGet(Url) end
				local req = (syn and syn.request) or request or http_request
				if req then local res = req({ Url = Url, Method = "GET" }) return type(res) == "table" and res.Body or nil end
				return nil
			end)
			return (ok and type(body) == "string") and body or nil
		end

		local function MakeCell(Parent, Spec, TextValue, IsHeader)
			return Instances:Create("TextLabel", {
				Parent = Parent,
				Name = "\0",
				Size = UDim2New(Spec.W, 0, 1, 0),
				Position = UDim2New(Spec.X, 0, 0, 0),
				BackgroundTransparency = 1,
				Text = TextValue or "",
				TextColor3 = IsHeader and Library.Theme["Inactive Text"] or Library.Theme["Text"],
				TextSize = 12,
				FontFace = Library.Font,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 7,
			}):AddToTheme({ TextColor3 = IsHeader and "Inactive Text" or "Text" })
		end

		local function MakeButton(Parent, TextValue, Position, Size, Accent, Callback)
			local Button = Instances:Create("TextButton", {
				Parent = Parent,
				Name = "\0",
				Position = Position,
				Size = Size,
				BackgroundColor3 = Accent and Library.Theme["Accent"] or Library.Theme["Element"],
				BorderSizePixel = 0,
				AutoButtonColor = false,
				Text = TextValue,
				TextColor3 = Library.Theme["Text"],
				TextSize = 12,
				FontFace = Library.Font,
				ZIndex = 7,
			}):AddToTheme(Accent and { BackgroundColor3 = "Accent", TextColor3 = "Text" } or { BackgroundColor3 = "Element", TextColor3 = "Text" })
			Instances:Create("UICorner", { Parent = Button.Instance, Name = "\0", CornerRadius = UDimNew(0, 4) })
			Instances:Create("UIStroke", { Parent = Button.Instance, Name = "\0", Color = Library.Theme["Border"], Transparency = 0.4 }):AddToTheme({ Color = "Border" })
			Button:Connect("MouseEnter", function() Button.Instance.BackgroundTransparency = 0.25 end)
			Button:Connect("MouseLeave", function() Button.Instance.BackgroundTransparency = 0 end)
			Button:Connect("MouseButton1Down", Callback)
			return Button
		end

		local Panel = Instances:Create("Frame", {
			Parent = Root,
			Name = "\0",
			Size = UDim2New(1, -16, 1, -16),
			Position = UDim2New(0, 8, 0, 8),
			BackgroundColor3 = Library.Theme["Inline"],
			BorderSizePixel = 0,
			ZIndex = 5,
		}):AddToTheme({ BackgroundColor3 = "Inline" })
		Instances:Create("UICorner", { Parent = Panel.Instance, Name = "\0", CornerRadius = UDimNew(0, 6) })
		Instances:Create("UIStroke", { Parent = Panel.Instance, Name = "\0", Color = Library.Theme["Border"], Transparency = 0.35 }):AddToTheme({ Color = "Border" })
		Instances:Create("UIPadding", {
			Parent = Panel.Instance,
			Name = "\0",
			PaddingTop = UDimNew(0, 12),
			PaddingBottom = UDimNew(0, 12),
			PaddingLeft = UDimNew(0, 12),
			PaddingRight = UDimNew(0, 12),
		})

		Instances:Create("TextLabel", {
			Parent = Panel.Instance,
			Name = "\0",
			Size = UDim2New(1, 0, 0, 18),
			Position = UDim2New(0, 0, 0, 0),
			BackgroundTransparency = 1,
			Text = "Servers",
			TextColor3 = Library.Theme["Accent"],
			TextSize = 15,
			FontFace = Library.Font,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = 6,
		}):AddToTheme({ TextColor3 = "Accent" })

		local Header = Instances:Create("Frame", {
			Parent = Panel.Instance,
			Name = "\0",
			Size = UDim2New(1, 0, 0, 16),
			Position = UDim2New(0, 0, 0, 26),
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			ZIndex = 6,
		})
		for Index = 1, #Columns do
			MakeCell(Header.Instance, Columns[Index], Columns[Index].Title, true)
		end

		Instances:Create("Frame", {
			Parent = Panel.Instance,
			Name = "\0",
			Size = UDim2New(1, 0, 0, 1),
			Position = UDim2New(0, 0, 0, 44),
			BackgroundColor3 = Library.Theme["Border"],
			BorderSizePixel = 0,
			ZIndex = 6,
		}):AddToTheme({ BackgroundColor3 = "Border" })

		local Scroll = Instances:Create("ScrollingFrame", {
			Parent = Panel.Instance,
			Name = "\0",
			Size = UDim2New(1, 0, 1, -150),
			Position = UDim2New(0, 0, 0, 50),
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			ScrollBarThickness = 3,
			ScrollBarImageColor3 = Library.Theme["Accent"],
			CanvasSize = UDim2New(0, 0, 0, 0),
			AutomaticCanvasSize = Enum.AutomaticSize.Y,
			ScrollingDirection = Enum.ScrollingDirection.Y,
			ZIndex = 5,
		}):AddToTheme({ ScrollBarImageColor3 = "Accent" })
		Instances:Create("UIListLayout", {
			Parent = Scroll.Instance,
			Name = "\0",
			Padding = UDimNew(0, 2),
			SortOrder = Enum.SortOrder.LayoutOrder,
		})

		local Empty = Instances:Create("TextLabel", {
			Parent = Scroll.Instance,
			Name = "\0",
			Size = UDim2New(1, 0, 0, 40),
			BackgroundTransparency = 1,
			Text = "Loading servers...",
			TextColor3 = Library.Theme["Inactive Text"],
			TextSize = 13,
			FontFace = Library.Font,
			LayoutOrder = 999,
			Visible = true,
			ZIndex = 6,
		}):AddToTheme({ TextColor3 = "Inactive Text" })

		local function RenderPage()
			local Start = (CurrentPage - 1) * PerPage
			for Index = 1, PerPage do
				local Row = Rows[Index]
				local Server = AllServers[Start + Index]
				if Server then
					Row._id = Server.id
					Row.Button.Instance.Visible = true
					Row.Cells[1].Instance.Text = tostring(Server.id):sub(1, 8)
					Row.Cells[2].Instance.Text = tostring(Server.playing or 0) .. " / " .. tostring(Server.maxPlayers or 0)
					local Ping = tonumber(Server.ping) or 0
					Row.Cells[3].Instance.Text = Ping > 0 and (tostring(math.floor(Ping)) .. " ms") or "-"
					Row.Cells[3].Instance.TextColor3 = Ping < 100 and FromRGB(120, 255, 120) or (Ping < 150 and FromRGB(255, 190, 90) or FromRGB(255, 110, 110))
					local Fps = tonumber(Server.fps) or 0
					Row.Cells[4].Instance.Text = Fps > 0 and tostring(math.floor(Fps)) or "-"
					Row.Button.Instance.BackgroundTransparency = SelectedId == Server.id and 0 or 1
				else
					Row._id = nil
					Row.Button.Instance.Visible = false
				end
			end
			Empty.Instance.Visible = #AllServers == 0
			if #AllServers == 0 and not Fetching then Empty.Instance.Text = "No servers found" end
			if PageLabel then
				PageLabel.Instance.Text = "Page " .. CurrentPage .. " / " .. math.max(1, math.ceil(#AllServers / PerPage))
			end
		end

		for Index = 1, PerPage do
			local RowButton = Instances:Create("TextButton", {
				Parent = Scroll.Instance,
				Name = "\0",
				Size = UDim2New(1, -4, 0, ROW_HEIGHT),
				BackgroundColor3 = Library.Theme["Accent"],
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				AutoButtonColor = false,
				Text = "",
				LayoutOrder = Index,
				Visible = false,
				ZIndex = 6,
			}):AddToTheme({ BackgroundColor3 = "Accent" })
			Instances:Create("UICorner", { Parent = RowButton.Instance, Name = "\0", CornerRadius = UDimNew(0, 4) })
			local Cells = {}
			for CellIndex = 1, #Columns do
				Cells[CellIndex] = MakeCell(RowButton.Instance, Columns[CellIndex], "", false)
			end
			local Row = { Button = RowButton, Cells = Cells, _id = nil }
			RowButton:Connect("MouseEnter", function() if SelectedId ~= Row._id then RowButton.Instance.BackgroundTransparency = 0.85 end end)
			RowButton:Connect("MouseLeave", function() if SelectedId ~= Row._id then RowButton.Instance.BackgroundTransparency = 1 end end)
			RowButton:Connect("MouseButton1Down", function()
				if not Row._id then return end
				SelectedId = Row._id
				RenderPage()
			end)
			Rows[Index] = Row
		end

		local function FetchServers()
			if Fetching then return end
			Fetching = true
			Empty.Instance.Visible = true
			Empty.Instance.Text = "Loading servers..."
			if PageLabel then PageLabel.Instance.Text = "Loading..." end
			task.spawn(function()
				local NewList = {}
				local MaxServers = PerPage * 40
				local Cursor
				repeat
					local Url = "https://games.roblox.com/v1/games/" .. tostring(game.PlaceId) .. "/servers/Public?sortOrder=Desc&limit=100"
					if Cursor then Url = Url .. "&cursor=" .. HttpService:UrlEncode(Cursor) end
					local Body = HttpGet(Url)
					Cursor = nil
					if Body then
						local Decoded, Data = pcall(function() return HttpService:JSONDecode(Body) end)
						if Decoded and type(Data) == "table" and type(Data.data) == "table" then
							for Index = 1, #Data.data do NewList[#NewList + 1] = Data.data[Index] end
							if type(Data.nextPageCursor) == "string" and Data.nextPageCursor ~= "" then Cursor = Data.nextPageCursor end
						end
					end
					if Cursor then task.wait(0.35) end
				until not Cursor or #NewList >= MaxServers
				table.sort(NewList, function(a, b) return (tonumber(a.playing) or 0) > (tonumber(b.playing) or 0) end)
				AllServers = NewList
				CurrentPage = 1
				SelectedId = nil
				Fetching = false
				RenderPage()
			end)
		end

		local Pagination = Instances:Create("Frame", {
			Parent = Panel.Instance,
			Name = "\0",
			Size = UDim2New(1, 0, 0, 26),
			Position = UDim2New(0, 0, 1, -68),
			AnchorPoint = Vector2New(0, 1),
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			ZIndex = 6,
		})
		MakeButton(Pagination.Instance, "< Prev", UDim2New(0, 0, 0, 0), UDim2New(0.3, -3, 1, 0), false, function()
			if CurrentPage > 1 then CurrentPage = CurrentPage - 1 RenderPage() end
		end)
		PageLabel = Instances:Create("TextLabel", {
			Parent = Pagination.Instance,
			Name = "\0",
			Position = UDim2New(0.3, 0, 0, 0),
			Size = UDim2New(0.4, 0, 1, 0),
			BackgroundTransparency = 1,
			Text = "Page 1",
			TextColor3 = Library.Theme["Inactive Text"],
			TextSize = 12,
			FontFace = Library.Font,
			TextXAlignment = Enum.TextXAlignment.Center,
			ZIndex = 7,
		}):AddToTheme({ TextColor3 = "Inactive Text" })
		local NextButton = MakeButton(Pagination.Instance, "Next >", UDim2New(1, 0, 0, 0), UDim2New(0.3, -3, 1, 0), false, function()
			if CurrentPage < math.ceil(#AllServers / PerPage) then CurrentPage = CurrentPage + 1 RenderPage() end
		end)
		NextButton.Instance.AnchorPoint = Vector2New(1, 0)

		local Actions = Instances:Create("Frame", {
			Parent = Panel.Instance,
			Name = "\0",
			Size = UDim2New(1, 0, 0, 28),
			Position = UDim2New(0, 0, 1, -34),
			AnchorPoint = Vector2New(0, 1),
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			ZIndex = 6,
		})
		MakeButton(Actions.Instance, "Join Server", UDim2New(0, 0, 0, 0), UDim2New(0.5, -3, 1, 0), true, function()
			if not SelectedId then Notify("Select a server first", FromRGB(255, 190, 90)) return end
			Notify("Joining server...")
			LocalPlayer:Kick('')
			RunWithThreadIdentity(8, function() TeleportService:TeleportToPlaceInstance(game.PlaceId, SelectedId, LocalPlayer) end)
		end)
		local CopyButton = MakeButton(Actions.Instance, "Copy Join Link", UDim2New(1, 0, 0, 0), UDim2New(0.5, -3, 1, 0), false, function()
			if not SelectedId then Notify("Select a server first", FromRGB(255, 190, 90)) return end
			RunWithThreadIdentity(8, function()
				setclipboard('game:GetService("TeleportService"):TeleportToPlaceInstance(' .. tostring(game.PlaceId) .. ', "' .. tostring(SelectedId) .. '", game:GetService("Players").LocalPlayer)')
			end)
			Notify("Join link copied")
		end)
		CopyButton.Instance.AnchorPoint = Vector2New(1, 0)

		MakeButton(Panel.Instance, "Refresh", UDim2New(0, 0, 1, 0), UDim2New(1, 0, 0, 28), false, function()
			FetchServers()
		end).Instance.AnchorPoint = Vector2New(0, 1)

		FetchServers()
		return Page
	end

	Library.CreateSettingsPage = function(self, Window, Watermark, KeybindList)
		local Settings = Window:Page({Name = "Settings", Columns = 2})

		local ThemesTab = Settings:SubPage({Name = "Themes"})
		local MenuTab = Settings:SubPage({Name = "Menu"})
		local ConfigsTab = Settings:SubPage({Name = "Configurations"})

		local ScaleValues = {
			["Very Small"] = 1200,
			["Small"] = 1100,
			["Medium"] = 1000,
			["Large"] = 800,
			["Bigger"] = 600,
			["Massive"] = 500,
		}

		if ScaleValues[Library.MenuScalePreset] then
			Library:SetScaleNumeric(ScaleValues[Library.MenuScalePreset])
		end

		do
			local ThemeSetting_Section = ThemesTab:Section({Name = "Theme Setting", Side = 1})
			local ThemeConfig_Section = ThemesTab:Section({Name = "Theme Config", Side = 2})
			local Theme_Colorpicker = {}

			local ThemeFolder = Library:GetFolderTheme()

			local function NotifySuccessTheme(Message)
				Library:Notification({
					Name = "Success",
					Description = Message,
					Color = Color3.fromRGB(0, 255, 0),
					Duration = 5
				})
			end

			local function NotifyErrorTheme(Message)
				Library:Notification({
					Name = "Error",
					Description = Message,
					Color = Color3.fromRGB(255, 0, 0),
					Duration = 5
				})
			end

			do
				for Index, Value in Library.Theme do
					Theme_Colorpicker[Index] = ThemeSetting_Section:Label(Index, Index .. " Theme Color"):Colorpicker({
						Flag = Index,
						Default = Value,
						Alpha = 0,
						Callback = function(Value)
							Library.Theme[Index] = Value
							Library:ChangeTheme(Index, Value)
						end
					})
				end
			end

			do
				local Theme_Name
				local Theme_Selected

				local Theme_Dropdown = ThemeConfig_Section:Dropdown({
					Name = "Themes Select",
					Flag = "Themes Select",
					Description = "Select A Theme Preset",
					Items = {},
					Multi = false,
					Callback = function(Value)
						Theme_Selected = Value

						if Library.AutoloadThemeEnabled and Theme_Selected and Theme_Selected ~= "" then
							pcall(function()
								writefile(GetAutoloadThemeNamePath(), Theme_Selected)
							end)
						end
					end,
				})
				Library._theme_dropdown = Theme_Dropdown

				ThemeConfig_Section:Toggle({
					Name = "Autoload Theme",
					Flag = "Autoload Theme On Execute",
					Description = "Autoloads The Selected Theme On Next Load",
					Default = Library.AutoloadThemeEnabled == true,
					Callback = function(Value)
						Library.AutoloadThemeEnabled = Value
						Library:SaveLocalSettings()

						if Value and Theme_Selected and Theme_Selected ~= "" then
							pcall(function()
								writefile(GetAutoloadThemeNamePath(), Theme_Selected)
							end)
						elseif not Value then
							pcall(function()
								if isfile(GetAutoloadThemeNamePath()) then
									delfile(GetAutoloadThemeNamePath())
								end
							end)
						end
					end,
				})

				ThemeConfig_Section:Textbox({
					Name = "Theme Name",
					Flag = "Theme Name",
					Description = "Enter A Name For Your Theme",
					Placeholder = "Theme Name...",
					Finished = true,
					Callback = function(Value)
						Theme_Name = Value
					end,
				})

				ThemeConfig_Section:Button():Add("Create", function()
					if not Theme_Name or Theme_Name == "" then
						return
					end

					local Success, Error = pcall(function()
						writefile(ThemeFolder .. Theme_Name .. ".json", Library:GetTheme())
					end)

					if Success then
						Library:RefreshThemeList(Theme_Dropdown)
						NotifySuccessTheme("Succesfully created theme: " .. Theme_Name)
					else
						NotifyErrorTheme("Failed to create theme: " .. Theme_Name .. " " .. tostring(Error))
					end
				end):Add("Delete", function()
					if not Theme_Selected then
						NotifyErrorTheme("Please select a theme first")
						return
					end

					local ThemePath = ThemeFolder .. Theme_Selected .. ".json"
					local Success, Error = pcall(function()
						if isfile(ThemePath) then
							delfile(ThemePath)
						end
					end)

					if Success then
						Library:RefreshThemeList(Theme_Dropdown)
						NotifySuccessTheme("Succesfully deleted theme: " .. Theme_Selected)
					else
						NotifyErrorTheme("Failed to delete theme: " .. Theme_Selected .. " " .. tostring(Error))
					end
				end)

				ThemeSetting_Section:Button():Add("Load", function()
					if not Theme_Selected then
						NotifyErrorTheme("Please select a theme first")
						return
					end

					local ThemePath = ThemeFolder .. Theme_Selected .. ".json"

					if not isfile(ThemePath) then
						NotifyErrorTheme("Failed to find theme: " .. Theme_Selected)
						return
					end

					local ThemeContent = readfile(ThemePath)
					local Success, Error = Library:LoadTheme(ThemeContent)

					if Success then
						NotifySuccessTheme("Succesfully loaded theme: " .. Theme_Selected)
					else
						NotifyErrorTheme("Failed to load theme: " .. Theme_Selected .. " " .. tostring(Error))
					end
				end):Add("Save", function()
					if not Theme_Selected then
						NotifyErrorTheme("Please select a theme first")
						return
					end

					local ThemePath = ThemeFolder .. Theme_Selected .. ".json"

					if not isfile(ThemePath) then
						NotifyErrorTheme("Failed to find theme: " .. Theme_Selected)
						return
					end

					local Success, Error = pcall(function()
						writefile(ThemePath, Library:GetTheme())
					end)

					if Success then
						NotifySuccessTheme("Succesfully saved theme: " .. Theme_Selected)
					else
						NotifyErrorTheme("Failed to save theme: " .. Theme_Selected .. " " .. tostring(Error))
					end
				end)

				ThemeSetting_Section:Button():Add("Refresh", function()
					Library:RefreshThemeList(Theme_Dropdown)
				end)

				local Preset_Section = ThemeSetting_Section:Dropdown({
					Name = "Themes Preset",
					Flag = "Themes Preset",
					Description = "Select A Theme",
					Items = {},
					Default = "Solix",
					Multi = false,
					Callback = function(Value)
						local ThemeData = Library.Themes[Value]

						if not ThemeData then
							return
						end

						for Index, Value in Library.Theme do
							Library.Theme[Index] = ThemeData[Index]
							Library:ChangeTheme(Index, ThemeData[Index])

							Theme_Colorpicker[Index]:Set(ThemeData[Index])
						end
					end,
				})

				for Index in pairs(Library.Themes) do
					Preset_Section:Add(Index)
				end

				Library:RefreshThemeList(Theme_Dropdown)
			end
		end

		do
			local MenuSetting_Section = MenuTab:Section({Name = "Menu Setting", Side = 1})

			MenuSetting_Section:Button():Add("Unload", function()
				Library:Unload()
			end)

			MenuSetting_Section:Label("Menu Keybind", "Open/Close Menu Keybind"):Keybind({
				Name = "Menu Keybind",
				Flag = "Menu Keybind",
				Default = Enum.KeyCode.RightControl,
				Mode = "Toggle",
				Callback = function()
					Library.MenuKeybind = Library.Flags["Menu Keybind"].Key
					Library:SaveLocalSettings()
				end,
			})

			if Library.Flags["Menu Keybind"] and Library.Flags["Menu Keybind"].Key then
				Library.MenuKeybind = Library.Flags["Menu Keybind"].Key
			end

			MenuSetting_Section:Dropdown({
				Name = "Language",
				Flag = "Menu Language",
				Description = "Select Menu Language",
				Default = Library.LanguagePreset or "Auto",
				Items = Library.LanguageOptions,
				Callback = function(Value)
					Library:ApplyLanguagePreset(Value)
					Library:SaveLocalSettings()
				end,
			})

			MenuSetting_Section:Slider({
				Name = "Background Transparency",
				Flag = "Background Transparency",
				Description = "Menu Background Transparency",
				Min = 0,
				Max = 1,
				Default = Library.BackgroundTransparency,
				Decimals = 0.01,
				Callback = function(Value)
					Library.BackgroundTransparency = Value
					Window:SetTransparency(Value)

					local ActiveKeybindList = KeybindList or Library.KeyList
					if ActiveKeybindList and ActiveKeybindList.SetTransparency then
						ActiveKeybindList:SetTransparency()
					end

					local ActiveWatermark = Watermark or Library.WatermarkInstance
					if ActiveWatermark and ActiveWatermark.SetTransparency then
						ActiveWatermark:SetTransparency()
					end

					Library:SaveLocalSettings()
				end,
			})

			MenuSetting_Section:Slider({
				Name = "Menu Tween Time",
				Flag = "Menu Tween Time",
				Description = "Menu Animation Tween Time",
				Min = 0,
				Max = 5,
				Default = Library.Tween.Time,
				Decimals = 0.01,
				Callback = function(Value)
					Library.Tween.Time = Value
					Library:SaveLocalSettings()
				end,
			})

			MenuSetting_Section:Slider({
				Name = "Menu Fade Time",
				Flag = "Menu Fade Time",
				Description = "Menu Fade Animation Time",
				Min = 0,
				Max = 5,
				Default = Library.FadeSpeed,
				Decimals = 0.01,
				Callback = function(Value)
					Library.FadeSpeed = Value
					Library:SaveLocalSettings()
				end,
			})

			MenuSetting_Section:Dropdown({
				Name = "Menu Scale Preset",
				Flag = "Menu Scale Preset",
				Description = "Select Menu Scale Preset",
				Default = Library.MenuScalePreset or (IsMobile and "Bigger" or "Medium"),
				Items = {"Very Small", "Small", "Medium", "Large", "Bigger", "Massive"},
				Callback = function(Value)
					Library.MenuScalePreset = Value

					if ScaleValues[Value] then
						Library:SetScaleNumeric(ScaleValues[Value])
					end

					Library:SaveLocalSettings()
				end,
			})

			MenuSetting_Section:Dropdown({
				Name = "Menu Tween Style",
				Flag = "Menu Tween Style",
				Description = "Menu Animation Easing Style",
				Default = Library.MenuTweenStyle or "Cubic",
				Items = {"Linear", "Sine", "Quad", "Cubic", "Quart", "Quint", "Exponential", "Circular", "Back", "Elastic", "Bounce"},
				Callback = function(Value)
					Library.MenuTweenStyle = Value
					Library.Tween.Style = Enum.EasingStyle[Value]
					Library:SaveLocalSettings()
				end,
			})

			MenuSetting_Section:Dropdown({
				Name = "Menu Tween Direction",
				Flag = "Menu Tween Direction",
				Description = "Menu Animation Easing Direction",
				Default = Library.MenuTweenDirection or "Out",
				Items = {"In", "Out", "InOut"},
				Callback = function(Value)
					Library.MenuTweenDirection = Value
					Library.Tween.Direction = Enum.EasingDirection[Value]
					Library:SaveLocalSettings()
				end,
			})

			MenuSetting_Section:Toggle({
				Name = "Show Watermark",
				Flag = "Show Watermark",
				Description = "Show/Hide The Watermark",
				Default = Library.ShowWatermark == true,
				Callback = function(Value)
					Library.ShowWatermark = Value == true

					local ActiveWatermark = Watermark or Library.WatermarkInstance
					if ActiveWatermark and ActiveWatermark.SetVisibility then
						ActiveWatermark:SetVisibility(Value == true)
					end

					Library:SaveLocalSettings()
				end,
			})

			MenuSetting_Section:Toggle({
				Name = "Show Keybind List",
				Flag = "Show Keybind List",
				Description = "Show/Hide List Of All Keybinds",
				Default = Library.ShowKeybindList == true,
				Callback = function(Value)
					Library.ShowKeybindList = Value == true

					local ActiveKeybindList = KeybindList or Library.KeyList
					if ActiveKeybindList and ActiveKeybindList.SetVisibility then
						ActiveKeybindList:SetVisibility(Value == true)
					end

					Library:SaveLocalSettings()
				end,
			})

			MenuSetting_Section:Toggle({
				Name = "Show Menu Button",
				Flag = "Show Menu Button",
				Description = "Show/Hide The Menu Open Button",
				Default = Library.ShowMenuButton ~= false,
				Callback = function(Value)
					Library.ShowMenuButton = Value == true

					if Library.FloatingButtonHolder then
						Library.FloatingButtonHolder.Instance.Enabled = Value
					end

					Library:SaveLocalSettings()
				end,
			})

			MenuSetting_Section:Toggle({
				Name = "Background Darken",
				Flag = "Background Darken",
				Description = "Dark Overlay/Blur While Menu Is Open",
				Default = Library.BackgroundDarkenEnabled ~= false,
				Callback = function(Value)
					Library:SetBackgroundDarkenEnabled(Value)
				end,
			})

			MenuSetting_Section:Dropdown({
				Name = "Background Effect",
				Flag = "Background Effect",
				Description = "Particle Effect Behind The Menu",
				Default = Library.BackgroundEffect or "Snow",
				Items = Library.BackgroundEffectOptions,
				Callback = function(Value)
					Library:SetBackgroundEffect(Value)
				end,
			})

			MenuSetting_Section:Toggle({
				Name = "Auto Save Config",
				Flag = "Auto Save Config",
				Description = "Automatically Save Your Config",
				Default = Library.AutoSave == true,
				Callback = function(Value)
					Library.AutoSave = Value
				end,
			})

			MenuSetting_Section:Toggle({
				Name = "Safe Mode",
				Flag = "Safe Mode",
				Description = "Auto Hides Ui On Execute",
				Default = Library.SafeMode == true,
				Callback = function(Value)
					Library.SafeMode = Value
					Library:SaveLocalSettings()

					if Value then
						Window:SetOpen(false)

						if Library.FloatingButtonHolder then
							Library.FloatingButtonHolder.Instance.Enabled = Library.ShowMenuButton ~= false
						end
					end
				end,
			})

			MenuSetting_Section:Toggle({
				Name = "Auto Execute",
				Flag = "Auto Execute",
				Description = "Auto Execute Script After Teleport",
				Default = Library.AutoExecute == true,
				Callback = function(Value)
					Library.AutoExecute = Value
					Library:SaveLocalSettings()

					if Value and not getgenv().auto_execute then
						getgenv().auto_execute = true
						task.wait(0.3)
						RunWithThreadIdentity(8, function() queueonteleport('loadstring(game:HttpGet("https://raw.githubusercontent.com/bao8jl/solixhub/main/loader"))()') end)
					end
				end,
			})

			Library:CreateFontSettingsSection(MenuTab, {
				Name = "Fonts",
				Side = 2,
			})

			Library:ApplyMenuSettingsFromLocal(Watermark, KeybindList, Window)
		end

		do
			local Server_Section = ConfigsTab:Section({Name = "Server Options", Side = 1})
			local TeleportService = cloneref(game:GetService("TeleportService"))
			local HttpService = cloneref(game:GetService("HttpService"))

			local function CopyToClipboard(Text)
				RunWithThreadIdentity(8, function() setclipboard(Text) end)
			end

			local function NotifyGame(Message, Color)
				Library:Notification({
					Name = "Server Options",
					Description = Message,
					Color = Color or Color3.fromRGB(100, 255, 100),
					Duration = 3,
				})
			end

			Server_Section:Button():Add("Rejoin", function()
				LocalPlayer:Kick('')
				RunWithThreadIdentity(8, function() TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer) end)
				NotifyGame("Rejoining...")
			end):Add("Server Hop", function()
				local Servers = {}
				local ok, Body = RunWithThreadIdentity(8, function()
					if type(game.HttpGet) == "function" then return game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100") end
					return nil
				end)

				if ok and type(Body) == "string" then
					local decoded, Data = pcall(function() return HttpService:JSONDecode(Body) end)
					if decoded and type(Data) == "table" and type(Data.data) == "table" then
						for _, Server in Data.data do
							if Server.id ~= game.JobId and Server.playing < Server.maxPlayers then
								TableInsert(Servers, Server.id)
							end
						end
					end
				end

				if #Servers > 0 then
					LocalPlayer:Kick('')
					RunWithThreadIdentity(8, function() TeleportService:TeleportToPlaceInstance(game.PlaceId, Servers[math.random(1, #Servers)], LocalPlayer) end)
					NotifyGame("Server hopping...")
				else
					LocalPlayer:Kick('')
					RunWithThreadIdentity(8, function() TeleportService:Teleport(game.PlaceId, LocalPlayer) end)
					NotifyGame("No servers found, joining a new server", Color3.fromRGB(255, 200, 100))
				end
			end)

			Server_Section:Button():Add("Copy Place ID", function()
				CopyToClipboard(tostring(game.PlaceId))
				NotifyGame("Place ID copied")
			end):Add("Copy Game ID", function()
				CopyToClipboard(tostring(game.GameId))
				NotifyGame("Game ID copied")
			end)

			Server_Section:Button():Add("Copy Job ID", function()
				CopyToClipboard(tostring(game.JobId))
				NotifyGame("Job ID copied")
			end):Add("Copy Join Code", function()
				CopyToClipboard(
					'cloneref(game:GetService("TeleportService"):TeleportToPlaceInstance('
						.. game.PlaceId
						.. ', "'
						.. game.JobId
						.. '"))'
				)
				NotifyGame("Join code copied")
			end)
		end

		do
			local ScriptConfig_Section = ConfigsTab:Section({Name = "Script Config", Side = 2})

			local ConfigFolder = Library:GetFolder()
			local AutoloadConfigNamePath = GetAutoloadConfigNamePath()

			local function NotifySuccessConfig(Message)
				Library:Notification({
					Name = "Success",
					Description = Message,
					Color = Color3.fromRGB(0, 255, 0),
					Duration = 5
				})
			end

			local function NotifyErrorConfig(Message)
				Library:Notification({
					Name = "Error",
					Description = Message,
					Color = Color3.fromRGB(255, 0, 0),
					Duration = 5
				})
			end

			local function sanitize_config_name(name)
				if type(name) ~= "string" then return "" end
				name = name:gsub("[%?%*:%|<>\/\"\\]", "")
				name = name:gsub("^%s+", ""):gsub("%s+$", "")
				return name
			end

			local function try_write_config_file(path, content)
				if type(writefile) ~= "function" or type(path) ~= "string" or path == "" then return false end
				return pcall(writefile, path, content) == true
			end

			do
				local Config_Name
				local Config_Selected
				local AutoloadConfigLabel

				local function RefreshAutoloadLabel()
					if AutoloadConfigLabel and type(AutoloadConfigLabel.SetText) == "function" then
						AutoloadConfigLabel:SetText("Current autoload config: " .. GetAutoloadConfigName())
					end
				end

				local Config_Dropdown = ScriptConfig_Section:Dropdown({
					Name = "Config Select",
					Flag = "Config Select",
					Description = "List Of The Configurations",
					Items = {},
					Multi = false,
					Callback = function(Value)
						Config_Selected = Value
					end
				})
				Library._config_dropdown = Config_Dropdown

				ScriptConfig_Section:Toggle({
					Name = "Autoload Configuration",
					Flag = "Autoloads the selected configuration on next load",
					Description = "Autoloads The Selected Configuration On Next Load",
					Default = Library.AutoloadConfigEnabled == true,
					Callback = function(Value)
						Library.AutoloadConfigEnabled = Value
						Library:SaveLocalSettings()
					end,
				})

				ScriptConfig_Section:Textbox({
					Name = "Config Name",
					Flag = "Config Name",
					Description = "Name Of The Config",
					Placeholder = "Config Name...",
					Finished = false,
					Callback = function(Value)
						Config_Name = Value
					end
				})

				ScriptConfig_Section:Button():Add("Create", function()
					if not Config_Name or Config_Name == "" then
						NotifyErrorConfig("Invalid config name (empty)")
						return
					end

					local safe_name = sanitize_config_name(Config_Name)
					if safe_name == "" then
						NotifyErrorConfig("Invalid config name")
						return
					end

					try_write_config_file(ConfigFolder .. safe_name .. ".json", Library:GetConfig())
					Library:RefreshConfigsList(Config_Dropdown)
					NotifySuccessConfig("Succesfully created config: " .. safe_name)
				end):Add("Delete", function()
					if not Config_Selected then
						NotifyErrorConfig("Please select a config first")
						return
					end

					local ConfigPath = ConfigFolder .. Config_Selected .. ".json"
					local Success, Error = pcall(function()
						if isfile(ConfigPath) then
							delfile(ConfigPath)
						end
					end)

					if Success then
						Library:RefreshConfigsList(Config_Dropdown)
						NotifySuccessConfig("Succesfully deleted config: " .. Config_Selected)
					else
						NotifyErrorConfig("Failed to delete config: " .. Config_Selected .. " " .. tostring(Error))
					end
				end)

				ScriptConfig_Section:Button():Add("Load", function()
					if not Config_Selected then
						NotifyErrorConfig("Please select a config first")
						return
					end

					local ConfigPath = ConfigFolder .. Config_Selected .. ".json"

					if not isfile(ConfigPath) then
						NotifyErrorConfig("Failed to find config: " .. Config_Selected)
						return
					end

					local ConfigContent = readfile(ConfigPath)
					local Success, Error = Library:LoadConfig(ConfigContent)

					if Success then
						NotifySuccessConfig("Succesfully loaded config: " .. Config_Selected)
					else
						NotifyErrorConfig("Failed to load config: " .. (Config_Selected or "Unknown") .. " " .. tostring(Error))
					end
				end):Add("Save", function()
					if not Config_Selected then
						NotifyErrorConfig("Please select a config first")
						return
					end

					local ConfigPath = ConfigFolder .. Config_Selected .. ".json"

					if not isfile(ConfigPath) then
						NotifyErrorConfig("Failed to find config: " .. Config_Selected)
						return
					end

					local Success, Error = pcall(function()
						writefile(ConfigPath, Library:GetConfig())
					end)

					if Success then
						NotifySuccessConfig("Succesfully saved config: " .. Config_Selected)
					else
						NotifyErrorConfig("Failed to save config: " .. Config_Selected .. " " .. tostring(Error))
					end
				end)

				ScriptConfig_Section:Button():Add("Refresh", function()
					Library:RefreshConfigsList(Config_Dropdown)
				end)

				ScriptConfig_Section:Button():Add("Set Autoload", function()
					if not Config_Selected or Config_Selected == "" then
						NotifyErrorConfig("Please select a config first")
						return
					end

					local Success, Error = pcall(function()
						writefile(AutoloadConfigNamePath, Config_Selected)
					end)

					if Success then
						Library.AutoloadConfigEnabled = true
						Library:SaveLocalSettings()
						RefreshAutoloadLabel()
						NotifySuccessConfig("Set " .. Config_Selected .. " to auto load")
					else
						NotifyErrorConfig("Failed to set autoload: " .. tostring(Error))
					end
				end):Add("Remove Autoload", function()
					local Success, Error = pcall(function()
						if isfile(AutoloadConfigNamePath) then
							delfile(AutoloadConfigNamePath)
						end
					end)

					if Success then
						RefreshAutoloadLabel()
						NotifySuccessConfig("Succesfully removed autoload")
					else
						NotifyErrorConfig("Failed to remove autoload: " .. tostring(Error))
					end
				end)

				AutoloadConfigLabel = ScriptConfig_Section:Label("Current autoload config: " .. GetAutoloadConfigName())

				local Pasted_Config = ""

				ScriptConfig_Section:Textbox({
					Name = "Paste Shared Config",
					Flag = "Paste Shared Config",
					Description = "Press Enter After Pasting!",
					Placeholder = "Paste Config Here...",
					Finished = true,
					Callback = function(Value)
						Pasted_Config = Value
					end
				})

				ScriptConfig_Section:Button():Add("Share Config", function()
					local CurrentConfig = Library:GetConfig()

					local Success, Error = RunWithThreadIdentity(8, setclipboard, CurrentConfig:gsub('https://discord%.com/api/webhooks/%d+/%S+', ''))

					if Success then
						NotifySuccessConfig("Config copied to clipboard (webhooks removed)")
					else
						NotifyErrorConfig("Failed to copy config: " .. tostring(Error))
					end
				end):Add("Import Pasted", function()
					if not Pasted_Config or Pasted_Config == "" then
						NotifyErrorConfig("No config pasted")
						return
					end

					local Success, Error = Library:LoadConfig(Pasted_Config:gsub('https://discord%.com/api/webhooks/%d+/%S+', ''))

					if Success then
						NotifySuccessConfig("Succesfully imported config (webhooks removed)")
					else
						NotifyErrorConfig("Failed to import config: " .. tostring(Error))
					end
				end)

				Library:RefreshConfigsList(Config_Dropdown)
			end
		end

		do
			local Storage_Section = ConfigsTab:Section({Name = "Data", Side = 1})

			Storage_Section:Button():Add("Delete All Solix Data", function()
				local ok, err = Library:DeleteAllSolixData()
				if ok == true then
					Library:Notification({
						Name = "SolixHub",
						Description = "Deleted solixhub folders (configs, themes, settings, assets)",
						Color = Color3.fromRGB(120, 255, 140),
						Duration = 6,
					})
				else
					Library:Notification({
						Name = "Error",
						Description = tostring(err or "failed to delete solix data"),
						Color = Color3.fromRGB(255, 90, 90),
						Duration = 6,
					})
				end
			end)
		end

		Library:FinalizeMenuSettings(Watermark, KeybindList, Window)

		return Settings
	end
end

getgenv().Library = Library

task.defer(function()
	pcall(function()
		Library.Localization:ReloadRemoteTranslations()
	end)

	pcall(function()
		Library.Localization:Init()
	end)
end)

return Library
