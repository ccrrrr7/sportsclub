    function library:get_storage_names(directory)
        local names = {}
        local seen_names = {}
        local success, files = pcall(function()
            return listfiles(directory)
        end)

        if not success or not files then
            library:debug_config("failed to list storage directory", directory, files)
            return names
        end

        for _, file in ipairs(files) do
            local file_name = file:match("([^\\/]+)$")
            local matched_name

            if file_name then
                for _, extension in ipairs(library.storage_extensions) do
                    matched_name = file_name:match("^(.*)%." .. extension .. "$")
                    if matched_name then
                        break
                    end
                end
            end

            if matched_name and not seen_names[matched_name] then
                seen_names[matched_name] = true
                names[#names + 1] = matched_name
            end
        end

        table.sort(names, function(left_name, right_name)
            return tostring(left_name):lower() < tostring(right_name):lower()
        end)

        return names
    end

