    sportsclub_functions["GetDirectZoneRadius"] = LPH_JIT_MAX(function(ball_speed, ball_velocity, hrp, hit_radius, parry_accuracy, smoothed_ping)
        local radius = math_max(hit_radius, 8)
        local extra = math_min((ball_speed / 120) * 10, 10)
        radius = math_max(radius, sportsclub_settings["AutoParryBaseHitRadius"] + extra + math_clamp(smoothed_ping * 0.004, 0, 0.6))

        if hrp then
            local velocity_mag = math_sqrt(ball_velocity.X * ball_velocity.X + ball_velocity.Y * ball_velocity.Y + ball_velocity.Z * ball_velocity.Z)
            if velocity_mag > 0.5 then
                local inv_velocity_mag = 1 / velocity_mag
                local dir_x = ball_velocity.X * inv_velocity_mag
                local dir_y = ball_velocity.Y * inv_velocity_mag
                local dir_z = ball_velocity.Z * inv_velocity_mag
                local look = hrp.CFrame.LookVector
                local up = hrp.CFrame.UpVector
                local dot_fwd = dir_x * look.X + dir_y * look.Y + dir_z * look.Z
                local dot_up = math_abs(dir_x * up.X + dir_y * up.Y + dir_z * up.Z)

                if dot_fwd > 0.35 then
                    local behind_extra = 4.5
                    if ball_speed >= 150 then
                        behind_extra = behind_extra + (ball_speed / 30)
                    end
                    radius = radius + behind_extra
                elseif math_abs(dot_fwd) <= 0.35 then
                    radius = radius + 1.5
                end

                if dot_up > 0.5 then
                    radius = radius + 1
                end
            end
        end

        if ball_speed >= 300 then
            radius = math_max(radius, 18)
        elseif ball_speed >= 200 then
            radius = math_max(radius, 14)
        elseif ball_speed >= 100 then
            radius = math_max(radius, 11)
        end

        return math_min(math_max(radius, hit_radius), math_max(hit_radius * 1.75, math_min(parry_accuracy * 0.84, 18.5)))
    end)

