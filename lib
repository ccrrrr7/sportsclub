                        local move = humanoid.MoveDirection
                        local moveDir = move.Magnitude > 0 and Vector3_new(camCFrame.LookVector.X, 0, camCFrame.LookVector.Z).Unit * move.Magnitude or Vector3_new(0, 0, 0)
                        if UserInputService:IsKeyDown(Enum.KeyCode.ButtonA) then y = 1 end
