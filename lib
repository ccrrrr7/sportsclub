	Library.RoundConfigNumber = function(self, Number, Decimals)
		if type(Number) ~= "number" then
			return Number
		end

		Decimals = Decimals or 4

		if Decimals <= 0 then
			return MathFloor(Number + 0.5)
		end

		local Multiplier = 10 ^ Decimals
		return MathFloor(Number * Multiplier + 0.5) / Multiplier
	end

	Library.CompactConfigValue = function(self, Value)
		if type(Value) == "number" then
			return self:RoundConfigNumber(Value, 4)
		end

		if type(Value) == "table" and Value.Key then
			return {
				Key = tostring(Value.Key),
				Mode = Value.Mode,
			}
		end

		if type(Value) == "table" and Value.Color then
			local HexValue = Value.HexValue or Value.Color

			if type(HexValue) == "string" and HexValue:sub(1, 1) == "#" then
				HexValue = HexValue:sub(2)
			end

			return {
				Color = "#" .. tostring(HexValue),
				Alpha = self:RoundConfigNumber(Value.Alpha or 0, 4),
			}
		end

		if type(Value) == "table" and (Value.Speed ~= nil or Value.Start ~= nil or Value["End"] ~= nil or Value.End ~= nil) then
			return {
				Speed = self:RoundConfigNumber(Value.Speed, 4),
				Start = self:RoundConfigNumber(Value.Start, 4),
				["End"] = self:RoundConfigNumber(Value["End"] or Value.End, 4),
			}
		end

		return Value
	end

	Library.ConfigValuesEqual = function(self, Left, Right)
		if type(Left) ~= type(Right) then
			return false
		end

		if type(Left) ~= "table" then
			return Left == Right
		end

		if Left.Key or Right.Key then
			return tostring(Left.Key) == tostring(Right.Key) and tostring(Left.Mode or "") == tostring(Right.Mode or "")
		end

		if Left.Color or Right.Color then
			local LeftHex = type(Left.Color) == "string" and Left.Color or (type(Left.HexValue) == "string" and Left.HexValue or "")
			local RightHex = type(Right.Color) == "string" and Right.Color or (type(Right.HexValue) == "string" and Right.HexValue or "")

			if LeftHex:sub(1, 1) == "#" then LeftHex = LeftHex:sub(2) end
			if RightHex:sub(1, 1) == "#" then RightHex = RightHex:sub(2) end

			return string.lower(LeftHex) == string.lower(RightHex)
				and self:RoundConfigNumber(Left.Alpha or 0, 4) == self:RoundConfigNumber(Right.Alpha or 0, 4)
		end

		if Left.Speed ~= nil or Right.Speed ~= nil or Left.Start ~= nil or Right.Start ~= nil or Left["End"] ~= nil or Right["End"] ~= nil then
			return self:RoundConfigNumber(Left.Speed, 4) == self:RoundConfigNumber(Right.Speed, 4)
				and self:RoundConfigNumber(Left.Start, 4) == self:RoundConfigNumber(Right.Start, 4)
				and self:RoundConfigNumber(Left["End"] or Left.End, 4) == self:RoundConfigNumber(Right["End"] or Right.End, 4)
		end

		return HttpService:JSONEncode(Left) == HttpService:JSONEncode(Right)
	end

	Library.DeferSectionLayoutRefresh = function(self, Section)
		if not Section then
			return
		end

		task.defer(function()
			if type(Section.UpdateColumnLayout) == "function" then
				pcall(Section.UpdateColumnLayout, Section)
			end

			local Page = Section.Page

			if Page and type(Page.UpdateColumnLayout) == "function" then
				pcall(Page.UpdateColumnLayout, Page)
			end
		end)
	end

	Library.AttachElementVisibilityApi = function(self, Element, InstanceWrapper)
		if type(Element) ~= "table" then
			return Element
		end

		function Element:SetVisibility(Bool)
			local Visible = Bool == true

			if InstanceWrapper and InstanceWrapper.Instance then
				InstanceWrapper.Instance.Visible = Visible
			end

			Library:DeferSectionLayoutRefresh(Element.Section)
		end

		Element.SetVisible = Element.SetVisibility

		return Element
	end

	Library.ResolveConfigSpeedValue = function(self, Value, Fallback)
		if type(Value) == "number" then
			return Value
		end

		if type(Value) == "table" and Value.Speed ~= nil then
			return tonumber(Value.Speed)
		end

		return Fallback
	end

	Library.NormalizeLoadedConfigValue = function(self, Flag, Value)
		if type(Value) == "number" and type(Flag) == "string" and self.HideRangeSubSliderFlags[Flag] == true then
			local DefaultValue = self.FlagDefaults[Flag]

			return {
				Speed = Value,
				Start = type(DefaultValue) == "table" and DefaultValue.Start or 0,
				["End"] = type(DefaultValue) == "table" and (DefaultValue["End"] or DefaultValue.End) or 100,
			}
		end

		if type(Value) ~= "table" then
			return Value
		end

		if type(Value.Key) == "string" then
			return Value
		end

		if type(Value.Color) == "string" then
			local Color = Value.Color

			if Color:sub(1, 1) ~= "#" then
				Color = "#" .. Color
			end

			return Color, Value.Alpha
		end

		if Value.Speed ~= nil or Value.Start ~= nil or Value["End"] ~= nil or Value.End ~= nil then
			return {
				Speed = Value.Speed,
				Start = Value.Start,
				["End"] = Value["End"] or Value.End,
			}
		end

		return Value
	end

	Library.StoreRawConfigFlag = function(self, Flag, Value)
		if type(Flag) ~= "string" or Flag == "" then
			return
		end

		if type(Value) == "table" and type(Value.Color) == "string" then
			local HexValue = Value.Color

			if HexValue:sub(1, 1) == "#" then
				HexValue = HexValue:sub(2)
			end

			self.Flags[Flag] = {
				Alpha = Value.Alpha or 0,
				Color = FromHex("#" .. HexValue),
				HexValue = HexValue,
				Flag = Flag,
				Transparency = 1 - (Value.Alpha or 0),
			}

			return
		end

		self.Flags[Flag] = Value
	end

