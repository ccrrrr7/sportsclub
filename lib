		function Window:SetOpen(Bool)
			local Lib = getgenv().Library
			if type(Lib) ~= "table" then
				return
			end

			if not Items["MainFrame"] or not Items["MainFrame"].Instance then
				return
			end

			Window.IsOpen = Bool
			Lib.WindowOpenState = Bool

			if type(Lib.OnMainVisibilityChanged) == "table" then
				for _, Callback in Lib.OnMainVisibilityChanged do
					if type(Callback) == "function" then pcall(Callback, Bool) end
				end
			end

			if type(Lib.ApplyMouseForMenu) == "function" then
				Lib:ApplyMouseForMenu(Bool)
			end

			if type(Lib.ApplyWindowInputState) == "function" then
				Lib:ApplyWindowInputState(Bool)
			end

			if type(Lib.SetBackgroundEffectsVisible) == "function" then
				Lib:SetBackgroundEffectsVisible(Bool)
			end

			if Debounce then
				Items["MainFrame"].Instance.Visible = Bool
				return
			end

			Debounce = true 

			if Window.IsOpen then 
				task.wait()
				Items["MainFrame"].Instance.Visible = true 
			end

			if type(Lib.OpenFrames) == "table" then
				for Index, Value in Lib.OpenFrames do
					if type(Value.SetOpen) == "function" then
						pcall(Value.SetOpen, Value, false)
					end
				end
			end

			local Descendants = Items["MainFrame"].Instance:GetDescendants()
			TableInsert(Descendants, Items["MainFrame"].Instance)

			local NewTween

			local TitleInstance = Items["Title"] and Items["Title"].Instance

			for Index, Value in Descendants do
				if TitleInstance and Value == TitleInstance then
					continue
				end

				local TransparencyProperty = Tween:GetProperty(Value)

				if not TransparencyProperty then
					continue 
				end

				if type(TransparencyProperty) == "table" then 
					for _, Property in TransparencyProperty do 
						NewTween = Tween:FadeItem(Value, Property, Bool, Lib.FadeSpeed or Library.FadeSpeed)
					end
				else
					NewTween = Tween:FadeItem(Value, TransparencyProperty, Bool, Lib.FadeSpeed or Library.FadeSpeed)
				end
			end

			if TitleInstance then
				TitleInstance.TextTransparency = Window.IsOpen and 0 or 1
			end

			if not NewTween or not NewTween.Tween then
				Debounce = false

				Items["MainFrame"].Instance.Visible = Window.IsOpen

				if type(Lib.ApplyMouseForMenu) == "function" then
					Lib:ApplyMouseForMenu(Window.IsOpen)
				end

				if type(Lib.ApplyWindowInputState) == "function" then
					Lib:ApplyWindowInputState(Window.IsOpen)
				end

				return
			end

			NewTween.Tween.Completed:Connect(function()
				Debounce = false

				Items["MainFrame"].Instance.Visible = Window.IsOpen

				if type(Lib.ApplyMouseForMenu) == "function" then
					Lib:ApplyMouseForMenu(Window.IsOpen)
				end

				if type(Lib.ApplyWindowInputState) == "function" then
					Lib:ApplyWindowInputState(Window.IsOpen)
				end

				if TitleInstance and Window.IsOpen then
					TitleInstance.TextTransparency = 0
				end
			end)
		end

