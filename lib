    function library:register_search_feature(tab_cfg, feature)
        if not tab_cfg or not feature or feature.text == nil then
            return
        end

        tab_cfg.search_features = tab_cfg.search_features or {}
        feature.kind = feature.kind or "control"
        feature.text_lower = string.lower(tostring(feature.text))
        feature.page_name = tostring(feature.page_name or "")
        feature.section_name = tostring(feature.section_name or "")

        if feature.info and feature.info ~= "" then
            feature.info_lower = string.lower(tostring(feature.info))
        end

        tab_cfg.search_features[#tab_cfg.search_features + 1] = feature
    end

    function library:feature_matches_search(feature, search_text)
        if search_text == "" then
            return true
        end

        local search_blob = feature.text_lower
            .. " "
            .. string.lower(feature.page_name)
            .. " "
            .. string.lower(feature.section_name)

        if feature.info_lower then
            search_blob = search_blob .. " " .. feature.info_lower
        end

        if feature.parent_control then
            search_blob = search_blob .. " " .. string.lower(tostring(feature.parent_control))
        end

        return string.find(search_blob, search_text, 1, true) ~= nil
    end

    function library:apply_tab_content_search(tab_cfg, search_text)
        if library.config_loading then
            return
        end

        search_text = tostring(search_text or ""):lower()

        if not tab_cfg or not tab_cfg.search_features then
            return
        end

        if search_text == "" then
            for _, feature in ipairs(tab_cfg.search_features) do
                if feature.holder and feature.holder.Parent then
                    feature.holder.Visible = true
                end
            end
            return
        end

        local is_selected_tab = library.menu_window and library.menu_window.selected_tab_data == tab_cfg
        if not is_selected_tab then
            return
        end

        local active_page = tab_cfg.current_multi
        local matched_page = nil

        for _, feature in ipairs(tab_cfg.search_features) do
            if library:feature_matches_search(feature, search_text) and feature.page then
                matched_page = feature.page
                break
            end
        end

        if matched_page and matched_page.open_page and tab_cfg.current_multi ~= matched_page then
            matched_page.open_page()
            active_page = matched_page
        end

        local section_visible = {}

        for _, feature in ipairs(tab_cfg.search_features) do
            local on_active_page = not feature.page or feature.page == active_page
            local matches = library:feature_matches_search(feature, search_text)

            if feature.kind == "section" then
                if on_active_page and matches and feature.holder and feature.holder.Parent then
                    feature.holder.Visible = true
                    section_visible[feature.holder] = true
                end
            elseif feature.holder and feature.holder.Parent and on_active_page then
                feature.holder.Visible = matches
                if matches and feature.section_outline then
                    section_visible[feature.section_outline] = true
                end
            end
        end

        for _, feature in ipairs(tab_cfg.search_features) do
            if feature.kind == "section" and feature.holder and feature.holder.Parent and feature.page == active_page then
                if not library:feature_matches_search(feature, search_text) then
                    feature.holder.Visible = section_visible[feature.holder] == true
                end
            end
        end
    end

