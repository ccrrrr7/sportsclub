    sportsclub_functions["PathInRadius"] = LPH_JIT_MAX(function(px, py, pz, cx, cy, cz, hx, hy, hz, radius)
        local abx = cx - px
        local aby = cy - py
        local abz = cz - pz
        local apx = hx - px
        local apy = hy - py
        local apz = hz - pz
        local ab_len2 = abx * abx + aby * aby + abz * abz
        if ab_len2 <= 0.0001 then
            local dx = hx - cx
            local dy = hy - cy
            local dz = hz - cz
            return (dx * dx + dy * dy + dz * dz) <= radius * radius
        end
        local t = math_clamp((apx * abx + apy * aby + apz * abz) / ab_len2, 0, 1)
