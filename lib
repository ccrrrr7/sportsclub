function random_string(length)
    local chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local str = ""
    for i = 1, length do
        str = str .. chars:sub(math_random(1, #chars), math_random(1, #chars))
    end
    return str
end

sportsclub_functions.expire_convert = LPH_NO_VIRTUALIZE(function(exp)
    if not exp or typeof(exp) ~= "number" then
        exp = 999999999999999
    end
    local r = os.time(os.date("!*t")) - exp
    if r >= 0 then return "Expired" end
    r = -r
    return string.format("%dd %dh %dm %ds", r//86400, (r%86400)//3600, (r%3600)//60, r%60)
end)

sportsclub_functions["OpenCrate"] = function(name, callback)
    if require(game.ReplicatedStorage.Packages.Replion).Client:WaitReplion("Data"):Get("Credits") < 80 then
        return false
    end
    for _, v in workspace:GetDescendants() do
        if v.Name == name and v:IsA("Model") then
            local lock = v:FindFirstChild("Lock")
            if lock then
                local prompt = lock:FindFirstChildWhichIsA("ProximityPrompt")
                if prompt then
                    fireproximityprompt(prompt)
                    if callback then callback() end
                    return true
                end
            end
            return false
        end
    end
    return false
end

