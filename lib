	local function GetDragScale(Gui)
		if Library.Holder and Library.Holder.Instance and Gui:IsDescendantOf(Library.Holder.Instance) then
			return Library.UIScaleNum or 1
		end

		return 1
	end

	local function GetScreenViewportSize()
		local Camera = Workspace.CurrentCamera
		return (Camera and Camera.ViewportSize) or Vector2New(1920, 1080)
	end

	local function GetFrameDragOffset(Gui)
		local Parent = Gui.Parent

		if not Parent then
			return Vector2New(0, 0)
		end

		local Scale = GetDragScale(Gui)
		local AbsPos = Gui.AbsolutePosition

		if Parent:IsA("GuiObject") then
			local ParentAbs = Parent.AbsolutePosition

			return Vector2New(
				(AbsPos.X - ParentAbs.X) / Scale,
				(AbsPos.Y - ParentAbs.Y) / Scale
			)
		end

		if Parent:IsA("ScreenGui") then
			return Vector2New(AbsPos.X / Scale, AbsPos.Y / Scale)
		end

		return Vector2New(0, 0)
	end

	local function ClampGuiDragOffset(Gui, DesiredOffset)
		local Parent = Gui.Parent

		if not Parent then
			return DesiredOffset
		end

		local Scale = GetDragScale(Gui)
		local ParentSize

		if Parent:IsA("GuiObject") then
			ParentSize = Parent.AbsoluteSize
		elseif Parent:IsA("ScreenGui") then
			ParentSize = GetScreenViewportSize()
		else
			return DesiredOffset
		end

		local GuiSize = Gui.AbsoluteSize
		local MaxX = math.max(0, (ParentSize.X - GuiSize.X) / Scale)
		local MaxY = math.max(0, (ParentSize.Y - GuiSize.Y) / Scale)

		return Vector2New(
			MathClamp(DesiredOffset.X, 0, MaxX),
			MathClamp(DesiredOffset.Y, 0, MaxY)
		)
	end

	local function ApplyDragOffset(Gui, Offset)
		Gui.AnchorPoint = Vector2New(0, 0)
		Gui.Position = UDim2FromOffset(Offset.X, Offset.Y)
	end

	local function NormalizeDragPosition(Gui)
		local Parent = Gui.Parent

		if not Parent or not Parent:IsA("GuiObject") then
			return
		end

		ApplyDragOffset(Gui, GetFrameDragOffset(Gui))
	end

