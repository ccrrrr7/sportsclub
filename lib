	Library.RegisterConfigFlag = function(self, Flag)
		if type(Flag) ~= "string" or Flag == "" then
			return
		end

		self.ScriptConfigFlags[Flag] = true
	end

	Library.IsScriptConfigFlag = function(self, Flag)
		if type(Flag) ~= "string" or Flag == "" then
			return false
		end

		if self.SettingsConfigFlags[Flag] == true then
			return false
		end

		if StringFind(Flag, "ThemingThing", 1, true) then
			return false
		end

		return self.ScriptConfigFlags[Flag] == true
	end

	Library.ResolveElementFlag = function(self, Data)
		if type(Data) ~= "table" then
			return nil
		end

		local Flag = Data.Flag or Data.flag
		if type(Flag) ~= "string" or Flag == "" then
			return nil
		end

		return Flag
	end

	Library.BindElementFlag = function(self, Flag, Setter, Element)
		if type(Flag) ~= "string" or Flag == "" or type(Setter) ~= "function" then
			return
		end

		self:RegisterConfigFlag(Flag)
		self.SetFlags[Flag] = Setter

		if type(Element) == "table" then
			if self.FlagDefaults[Flag] == nil then
				if Element.Default ~= nil then
					self:RegisterFlagDefault(Flag, Element.Default)
				elseif Element.Value ~= nil then
					self:RegisterFlagDefault(Flag, Element.Value)
				end
			end

			if type(Element.Callback) == "function" then
				local element = Element

				self.ConfigFlagCallbacks[Flag] = function()
					if element.Disabled == true then
						return
					end

					if type(element.SyncVisibleChildren) == "function" then
						pcall(element.SyncVisibleChildren, element, element.Value == true)
					end

					self:SafeCall(element.Callback, element.Value)
				end
			end
		end
	end

	Library.RegisterConfigFlagCallback = function(self, Flag, Callback)
		if type(Flag) ~= "string" or Flag == "" or type(Callback) ~= "function" then
			return
		end

		local ExistingCallback = self.ConfigFlagCallbacks[Flag]

		if type(ExistingCallback) == "function" then
			self.ConfigFlagCallbacks[Flag] = function()
				self:SafeCall(ExistingCallback)
				self:SafeCall(Callback)
			end
		else
			self.ConfigFlagCallbacks[Flag] = Callback
		end
	end

	Library.FireConfigFlagCallbacks = function(self, Decoded)
		if type(Decoded) ~= "table" then
			return
		end

		local OrderedFlags = {}

		for Index, _ in Decoded do
			if self:IsScriptConfigFlag(Index) == true then
				TableInsert(OrderedFlags, Index)
			end
		end

		table.sort(OrderedFlags, function(Left, Right)
			local LeftPriority = StringFind(Left, "_enabled", 1, true) ~= nil and 0 or 1
			local RightPriority = StringFind(Right, "_enabled", 1, true) ~= nil and 0 or 1

			if LeftPriority ~= RightPriority then
				return LeftPriority < RightPriority
			end

			return Left < Right
		end)

		for Index = 1, #OrderedFlags do
			local Flag = OrderedFlags[Index]
			local Callback = self.ConfigFlagCallbacks[Flag]

			if type(Callback) == "function" then
				self:SafeCall(Callback)
			end
		end
	end

	Library.FinishConfigLoad = function(self, Decoded, FailedEntries)
		self.LoadingConfig = false
		self:EndSilent()

		self:FireConfigFlagCallbacks(Decoded)

		task.defer(function()
			for _, Callback in self.ConfigLoadedCallbacks do
				self:SafeCall(Callback, #FailedEntries == 0, FailedEntries)
			end

			if #FailedEntries > 0 then
				warn("[Solix] Config loaded with " .. tostring(#FailedEntries) .. " warning(s): " .. tostring(FailedEntries[1]))
			end
		end)
	end

