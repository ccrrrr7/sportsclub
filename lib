    end)

    sportsclub_functions["GetRawPing"] = LPH_JIT(function()
        local ping_item = sportsclub_settings["DataPingItem"]
        local ping_string = nil
        if ping_item then
            local ok, result = pcall(function()
                return ping_item:GetValueString()
            end)
            if ok then
                ping_string = result
            end
        end
        local parsed_ping = ping_string and tonumber(string_match(ping_string, "[%d%.]+")) or nil
        if parsed_ping then
            local_ping = parsed_ping
            return parsed_ping
        end
        return local_ping
    end)

    sportsclub_functions["UpdatePingStats"] = LPH_NO_VIRTUALIZE(function()
        local samples = sportsclub_settings["PingSamples"]
        local sample_count = #samples
        local raw_ping = sportsclub_functions["GetRawPing"]()
        local next_index = (sportsclub_settings["PingSampleIndex"] % sample_count) + 1
        sportsclub_settings["PingSampleIndex"] = next_index
        sportsclub_settings["PingSampleCount"] = math_min(sportsclub_settings["PingSampleCount"] + 1, sample_count)
        samples[next_index] = raw_ping
        local total = 0
        local count = sportsclub_settings["PingSampleCount"]
        for i = 1, count do
            total = total + samples[i]
        end
        local smoothed_ping = count > 0 and (total / count) or raw_ping
        local deviation = 0
        for i = 1, count do
            deviation = deviation + abs(samples[i] - smoothed_ping)
        end
        local jitter = count > 0 and (deviation / count) or 0
        sportsclub_settings["SmoothedPing"] = smoothed_ping
        sportsclub_settings["PingJitter"] = jitter
        return raw_ping, smoothed_ping, jitter
    end)

    sportsclub_functions["SimulateTTI"] = LPH_JIT_MAX(function(bx, by, bz, vx, vy, vz, hx, hy, hz, hit_radius, ax, ay, az)
        local grav_y = sportsclub_settings["GravY"]
        local r2 = hit_radius * hit_radius
        local dt = 0.008
        local cur_vx, cur_vy, cur_vz = vx, vy, vz
        local cur_bx, cur_by, cur_bz = bx, by, bz
        local prev_dist2 = math_huge
        local away_steps = 0
        local acc_x = ax or 0
        local acc_y = ay or 0
        local acc_z = az or 0
        local best_dist2 = math_huge
        local sim_fallback_used = false

        for i = 1, 300 do
            cur_vx = cur_vx + acc_x * dt
            cur_vy = cur_vy + (grav_y + acc_y) * dt
            cur_vz = cur_vz + acc_z * dt
            cur_bx = cur_bx + cur_vx * dt
            cur_by = cur_by + cur_vy * dt
            cur_bz = cur_bz + cur_vz * dt
            local dx = hx - cur_bx
            local dy = hy - cur_by
            local dz = hz - cur_bz
            local dist2 = dx*dx + dy*dy + dz*dz
            best_dist2 = math_min(best_dist2, dist2)
            if dist2 <= r2 then
                return i * dt, false
            end
            if i > 12 and dist2 > prev_dist2 + 12 then
                away_steps = away_steps + 1
            else
                away_steps = 0
            end
            if i > 40 and away_steps >= 8 then
                sim_fallback_used = true
                break
            end
            prev_dist2 = dist2
        end

        local dx = hx - cur_bx
        local dy = hy - cur_by
        local dz = hz - cur_bz
        local remaining_dist = math_max(math_sqrt(math_min(best_dist2, dx*dx + dy*dy + dz*dz)) - hit_radius, 0)
        local current_dist = math_max(math_sqrt(dx*dx + dy*dy + dz*dz), 0.001)
        local closing_speed = ((cur_vx * dx) + (cur_vy * dy) + (cur_vz * dz)) / current_dist
        if closing_speed > 1 then
            sim_fallback_used = true
            return remaining_dist / closing_speed, sim_fallback_used
        end
        local speed = math_sqrt(cur_vx * cur_vx + cur_vy * cur_vy + cur_vz * cur_vz)
        if speed > 0.5 then
            sim_fallback_used = true
            return math_max(remaining_dist, 0) / math_max(speed * 0.65, 1), sim_fallback_used
        end
        return math_max(remaining_dist, 0) / 1.25, sim_fallback_used
    end)

    sportsclub_functions["GetMyBall"] = LPH_JIT_MAX(function()
        local player_name = LocalPlayer.Name
        for _, ball in workspace.Balls:GetChildren() do
            if ball:GetAttribute("realBall") == true and ball:GetAttribute("target") == player_name then
                return ball, ball:FindFirstChild("Body") or ball
            end
        end
        return nil, nil
    end)

    sportsclub_functions["SafeVelocity"] = LPH_JIT_MAX(function(part)
        if not part then
            return Vector3_new(0, 0, 0)
        end
        local zoomies = part:FindFirstChild("zoomies") or (part.Parent and part.Parent:FindFirstChild("zoomies"))
        if zoomies then
            local ok, vel = pcall(function() return zoomies.VectorVelocity end)
            if ok and vel then
                return vel
