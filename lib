            if mouse_restore_connection then
                mouse_restore_connection:Disconnect()
                mouse_restore_connection = nil
            end
        end

        local function restore_menu_mouse()
            stop_mouse_connections()

            local saved = mouse_state_before_open
            mouse_state_before_open = nil

            apply_game_menu_mouse(false)
            apply_saved_mouse(saved)

            if not saved then
                uis.MouseBehavior = Enum.MouseBehavior.Default
                uis.MouseIconEnabled = true
                return
            end

            local frames = 0
            mouse_restore_connection = run.PreRender:Connect(function()
                if library["items"] and library["items"].Enabled == true then
                    stop_mouse_connections()
                    return
                end

                apply_saved_mouse(saved)
                frames += 1

                if frames >= 8 then
                    stop_mouse_connections()
                end
            end)

            task.defer(function()
                if library["items"] and library["items"].Enabled == true then
                    return
                end

                apply_saved_mouse(saved)
            end)
        end

        function cfg.toggle_menu(bool)
            library["items"].Enabled = bool
            library:update_mobile_menu_button()

            if bool == true then
                stop_mouse_connections()

                if not mouse_state_before_open then
                    mouse_state_before_open = {
                        MouseBehavior = uis.MouseBehavior,
                        MouseIconEnabled = uis.MouseIconEnabled,
                    }
                end

                apply_game_menu_mouse(true)
                apply_menu_mouse_unlock()

                mouse_unlock_connection = run.PreRender:Connect(function()
                    if not library["items"] or library["items"].Enabled ~= true then
                        return
                    end

                    apply_menu_mouse_unlock()
                end)
            else
                restore_menu_mouse()
            end
        end
            
        return setmetatable(cfg, library)
    end 

