    function library:draggify(frame)
        library:ensure_size_lock_gui()

        local dragging = false 
        local start_size = frame.Position
        local start 

        library:connection(frame.InputBegan, function(input)
            if library:is_size_locked() then
                return
            end

            if library:is_primary_input(input) then
                dragging = true
                start = input.Position
                start_size = frame.Position
            end
        end)

        library:connection(frame.InputEnded, function(input)
            if library:is_primary_input(input) then
                dragging = false
            end
        end)

        library:connection(uis.InputChanged, function(input, game_event) 
            if library:is_size_locked() then
                return
            end

            if dragging and library:is_pointer_movement(input) then
                local drag_bounds = library:get_drag_bounds(frame)

                local current_position = dim2(
                    0,
                    clamp(
                        start_size.X.Offset + (input.Position.X - start.X),
                        drag_bounds.min_x,
                        drag_bounds.max_x
                    ),
                    0,
                    clamp(
                        start_size.Y.Offset + (input.Position.Y - start.Y),
                        drag_bounds.min_y,
                        drag_bounds.max_y
                    )
                )

                frame.Position = current_position
                library:close_element()
            end
        end)
