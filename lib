        function cfg.tab_matches_search(entry)
            if cfg.search_text == "" then
                return true
            end

            if string.find(string.lower(entry.text), cfg.search_text, 1, true) then
                return true
            end

            if entry.tab and entry.tab.search_features then
                for _, feature in ipairs(entry.tab.search_features) do
                    if library:feature_matches_search(feature, cfg.search_text) then
                        return true
                    end
                end
            end

            return false
        end

        function cfg.update_sidebar_search(search_text)
            cfg.search_text = tostring(search_text or ""):lower()

            local visible_tabs = {}
            local first_visible_tab = nil

            for _, entry in ipairs(cfg.search_entries) do
                if entry.kind == "tab" then
                    local is_visible = cfg.tab_matches_search(entry)
                    entry.object.Visible = is_visible
                    visible_tabs[entry] = is_visible

                    if is_visible and not first_visible_tab then
                        first_visible_tab = entry
                    end
                end
            end

            local current_separator = nil
            local separator_has_visible_tab = false

            local function apply_separator_visibility()
                if not current_separator then
                    return
                end

                current_separator.object.Visible = separator_has_visible_tab or cfg.search_text == "" or string.find(string.lower(current_separator.text), cfg.search_text, 1, true) ~= nil
            end

            for _, entry in ipairs(cfg.search_entries) do
                if entry.kind == "separator" then
                    apply_separator_visibility()
                    current_separator = entry
                    separator_has_visible_tab = false
                elseif entry.kind == "tab" and visible_tabs[entry] then
                    separator_has_visible_tab = true
                end
            end

            apply_separator_visibility()

            for _, tab_cfg in ipairs(cfg.tabs) do
                library:apply_tab_content_search(tab_cfg, cfg.search_text)
            end

            local selected_tab_data = library.menu_window and library.menu_window.selected_tab_data
            if first_visible_tab and selected_tab_data and not visible_tabs[selected_tab_data.search_entry] then
                first_visible_tab.tab.open_tab()
                library:apply_tab_content_search(first_visible_tab.tab, cfg.search_text)
            elseif selected_tab_data and visible_tabs[selected_tab_data.search_entry] then
                library:apply_tab_content_search(selected_tab_data, cfg.search_text)
            end
        end

