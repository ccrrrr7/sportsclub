    end)

    sportsclub_functions["PredictCurveThreat"] = LPH_JIT_MAX(function(history, curve_strength, heading_rotation, dot_trend, dist, closeness_trend, lateral_accel, eta_stability, direction_changed_recently)
        local count = history.count
        if count < 4 then
            return false, 0, 0, 0
        end

        local dot_swing_total = 0
        local dot_swing_max = 0
        local dist_flip_count = 0
        local closing_consistency = 0
        local last_dot = history.dot[((history.index - count + history.size - 1) % history.size) + 1]
        local last_dist_delta = nil

        for offset = count - 1, 1, -1 do
