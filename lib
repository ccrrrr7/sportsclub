		local paths = GetFolders()
		local folders = {
			paths.Directory,
			paths.Assets,
			paths.Assets .. "/Audios",
			paths.Assets .. "/Fonts",
			paths.Configurations,
			paths.Images,
			paths.Themes,
			paths.Configurations .. "/" .. GameId,
			paths.Datas .. "/" .. GameId,
		}
		for index = 1, #folders do
			if not isfolder(folders[index]) then
				pcall(makefolder, folders[index])
			end
		end
	end

	Library.DeleteAllSolixData = function(self)
		if type(delfile) ~= "function" and type(delfolder) ~= "function" then
			return false, "filesystem unsupported"
		end
		local function wipe_path(path)
			if type(path) ~= "string" or path == "" then return end
			if isfile(path) then
				pcall(delfile, path)
				return
			end
			if not isfolder(path) then return end
			if type(listfiles) == "function" then
				local ok_list, entries = pcall(listfiles, path)
				if ok_list and type(entries) == "table" then
					for index = 1, #entries do
						wipe_path(entries[index])
					end
				end
			end
			pcall(delfolder, path)
		end
		wipe_path("solixhub")
		wipe_path("SolixHub")
		self.AutoloadConfigEnabled = false
		self.AutoloadThemeEnabled = false
		self:EnsureFolders()
		if self._config_dropdown then
			pcall(function() self:RefreshConfigsList(self._config_dropdown) end)
		end
		if self._theme_dropdown then
			pcall(function() self:RefreshThemeList(self._theme_dropdown) end)
		end
		return true
	end

