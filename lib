                Size = dim2(1, -4, 1, -4);
                Position = dim2(0, 2, 0, library:is_mobile() and 4 or 2);
                ScaleType = Enum.ScaleType.Fit;
            })
            library:create("ImageLabel", {
                Parent = Frame;
                BackgroundTransparency = 1;
                BorderSizePixel = 0;
                Image = ResizeIcon.Url;
                ImageRectOffset = ResizeIcon.ImageRectOffset;
                ImageRectSize = ResizeIcon.ImageRectSize;
                ImageColor3 = rgb(205, 205, 205);
                Size = dim2(1, -4, 1, -4);
                Position = dim2(0, 2, 0, library:is_mobile() and -4 or -2);
                Rotation = 180;
                ScaleType = Enum.ScaleType.Fit;
            })
        else
            library:create("TextLabel", {
                Parent = Frame;
                BackgroundTransparency = 1;
                BorderSizePixel = 0;
                Text = "↘";
                TextColor3 = rgb(205, 205, 205);
                FontFace = fonts.font;
