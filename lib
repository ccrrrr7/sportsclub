    function library:tween(obj, properties, easing_style, time)
        if not obj then
            return
        end
        local ok = pcall(function()
            tween_service:Create(obj, TweenInfo.new(time or 0.25, easing_style or Enum.EasingStyle.Quint, Enum.EasingDirection.InOut, 0, false, 0), properties):Play()
        end)
        return ok
    end

    function library:is_mobile()
        if uis.TouchEnabled and not uis.MouseEnabled then
            return true
        end

        local platform = uis:GetPlatform()
        return platform == Enum.Platform.Android or platform == Enum.Platform.IOS
    end

    function library:get_window_size(properties)
        local size = properties.size or properties.Size
        local viewport = camera and camera.ViewportSize or Vector2.new(1024, 768)

        if size then
            return size
        end

        if library:is_mobile() then
            return dim2(0, math.clamp(viewport.X - 24, 360, 480), 0, math.clamp(viewport.Y - 24, 280, 380))
        end

        return dim2(0, math.clamp(viewport.X - 24, 640, 720), 0, math.clamp(viewport.Y - 24, 520, 620))
    end

    function library:get_min_window_size()
        if library:is_mobile() then
            return Vector2.new(360, 280)
        end

        return Vector2.new(520, 420)
    end

    function library:get_drag_bounds(frame)
        local viewport_size = camera.ViewportSize
        local visible_width = library:is_mobile() and 120 or 160
        local visible_height = library:is_mobile() and 60 or 90

        return {
            min_x = visible_width - frame.Size.X.Offset;
            max_x = viewport_size.X - visible_width;
            min_y = 0;
            max_y = viewport_size.Y - visible_height;
        }
    end

    function library:fit_to_viewport(frame)
        local drag_bounds = library:get_drag_bounds(frame)

        frame.Position = dim2(
            0,
            clamp(frame.Position.X.Offset, drag_bounds.min_x, drag_bounds.max_x),
            0,
            clamp(frame.Position.Y.Offset, drag_bounds.min_y, drag_bounds.max_y)
        )
    end

    function library:resizify(frame) 
        library:ensure_size_lock_gui()

        local resize_hit_size = library:is_mobile() and 36 or 22
        local resize_inset = library:is_mobile() and 8 or 4

        local Frame = Instance.new("TextButton")
